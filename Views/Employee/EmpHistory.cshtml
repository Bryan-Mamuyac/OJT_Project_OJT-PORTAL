@model List<TaskSubmission>
@{
    ViewData["Title"] = "History";
    var cancelledTasks = ViewBag.CancelledTasks as List<ITPMS_OJT.Models.TaskItem> ?? new();

    // Unified filter options from BOTH tables
    var allBranches = Model.Select(s => s.OJTBranch ?? "")
        .Concat(cancelledTasks.Select(t => t.AssignedToBranch ?? ""))
        .Where(b => b != "").Distinct().OrderBy(b => b).ToList();

    var allOJTs = Model.Select(s => s.OJTName ?? "")
        .Concat(cancelledTasks.Select(t => t.AssignedToName ?? ""))
        .Where(n => n != "").Distinct().OrderBy(n => n).ToList();

    bool hasFilter = allBranches.Any() || allOJTs.Any();
}

<div class="dashboard">
    <div class="section-card">

        <div class="section-header" style="flex-wrap:wrap;gap:10px;">
            <h3><i class="fas fa-history"></i> History</h3>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <span class="hist-pill pill-approved"><i class="fas fa-check-circle"></i> @Model.Count Approved</span>
                <span class="hist-pill pill-cancelled"><i class="fas fa-ban"></i> @cancelledTasks.Count Cancelled</span>
            </div>
        </div>

        @if (hasFilter)
        {
            <div class="hf-bar">
                <span class="hf-bar-title"><i class="fas fa-filter"></i> Filter Both Sections</span>
                <div class="hf-controls">
                    @if (allBranches.Any())
                    {
                        <div class="hf-group">
                            <label class="hf-label"><i class="fas fa-map-marker-alt"></i> Branch</label>
                            <select id="gBranch" class="hf-select" onchange="applyFilters()">
                                <option value="">All Branches</option>
                                @foreach (var b in allBranches)
                                {
                                    <option value="@b">@b</option>
                                }
                            </select>
                        </div>
                    }
                    @if (allOJTs.Any())
                    {
                        <div class="hf-group">
                            <label class="hf-label"><i class="fas fa-user-graduate"></i> OJT Trainee</label>
                            <select id="gOJT" class="hf-select" onchange="applyFilters()">
                                <option value="">All Trainees</option>
                                @foreach (var n in allOJTs)
                                {
                                    <option value="@n">@n</option>
                                }
                            </select>
                        </div>
                    }
                    <button type="button" class="hf-clear" onclick="clearFilters()"><i class="fas fa-times"></i> Clear</button>
                </div>
            </div>
        }

        <div class="section-body">

            <!-- Approved Submissions -->
            <div class="hist-section-label approved-label">
                <i class="fas fa-check-circle"></i> Approved Submissions
            </div>
            @if (!Model.Any())
            {
                <div class="empty-state" style="padding:24px 0;">
                    <i class="fas fa-check-circle" style="font-size:2rem;color:#d1fae5;"></i>
                    <p style="margin-top:8px;">No approved submissions yet.</p>
                </div>
            }
            else
            {
                <div class="hist-scroll">
                    <table class="hist-table" id="appTable">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>OJT Trainee</th>
                                <th>Branch</th>
                                <th>Submission Title</th>
                                <th>Submitted</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sub in Model)
                            {
                                <tr data-branch="@(sub.OJTBranch ?? "")" data-ojt="@(sub.OJTName ?? "")">
                                    <td><strong>@sub.TaskTitle</strong></td>
                                    <td>@sub.OJTName</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(sub.OJTBranch))
                                        {
                                            <span class="meta-branch"><i class="fas fa-map-marker-alt"></i> @sub.OJTBranch</span>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>@sub.SubmissionTitle</td>
                                    <td style="white-space:nowrap;">@sub.SubmittedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    <td><span class="status-badge status-approved">Approved</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Cancelled Tasks -->
            <div class="hist-section-label cancelled-label" style="margin-top:28px;">
                <i class="fas fa-ban"></i> Cancelled Tasks
            </div>
            @if (!cancelledTasks.Any())
            {
                <div class="empty-state" style="padding:24px 0;">
                    <i class="fas fa-ban" style="font-size:2rem;color:#fee2e2;"></i>
                    <p style="margin-top:8px;">No cancelled tasks yet.</p>
                </div>
            }
            else
            {
                <div class="hist-scroll">
                    <table class="hist-table" id="canTable">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>OJT Trainee</th>
                                <th>Branch</th>
                                <th>Cancelled On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in cancelledTasks)
                            {
                                <tr data-branch="@(t.AssignedToBranch ?? "")" data-ojt="@(t.AssignedToName ?? "")">
                                    <td><strong>@t.Title</strong></td>
                                    <td>@t.AssignedToName</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(t.AssignedToBranch))
                                        {
                                            <span class="meta-branch"><i class="fas fa-map-marker-alt"></i> @t.AssignedToBranch</span>
                                        }
                                        else
                                        {

                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">@t.UpdatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    <td><span class="status-badge status-cancelled">Cancelled</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>

@section Styles {
    <style>
        .hist-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: .78rem;
            font-weight: 600;
        }

        .pill-approved {
            background: #dcfce7;
            color: #15803d;
        }

        .pill-cancelled {
            background: #fee2e2;
            color: #dc2626;
        }

        .hf-bar {
            padding: 14px 20px;
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .hf-bar-title {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .hf-bar-title i {
                color: #2563ab;
                font-size: .65rem;
            }

        .hf-controls {
            display: flex;
            align-items: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .hf-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .hf-label {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .hf-label i {
                font-size: .6rem;
                color: #2563ab;
            }

        .hf-select {
            height: 34px;
            padding: 0 10px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #1e293b;
            font-size: .82rem;
            cursor: pointer;
            outline: none;
            min-width: 150px;
            transition: border-color .15s;
        }

            .hf-select:focus {
                border-color: #2563ab;
            }

        .hf-clear {
            height: 34px;
            padding: 0 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #64748b;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all .15s;
            align-self: flex-end;
        }

            .hf-clear:hover {
                border-color: #94a3b8;
                background: #f1f5f9;
                color: #1e293b;
            }

        .hist-row-hidden {
            display: none !important;
        }

        .hist-section-label {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 7px 0 10px;
            border-bottom: 2px solid #f1f5f9;
            margin-bottom: 14px;
        }

        .approved-label {
            color: #16a34a;
            border-color: #dcfce7;
        }

        .cancelled-label {
            color: #dc2626;
            border-color: #fee2e2;
        }

        .hist-table {
            width: 100%;
            border-collapse: collapse;
        }

            .hist-table th {
                padding: 9px 14px;
                font-size: .69rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .5px;
                color: #94a3b8;
                border-bottom: 2px solid #e2e8f0;
                white-space: nowrap;
            }

            .hist-table td {
                padding: 10px 14px;
                font-size: .83rem;
                border-bottom: 1px solid #f1f5f9;
                vertical-align: middle;
            }

            .hist-table tbody tr:hover {
                background: #f8fafc;
            }

            .hist-table td strong {
                display: block;
                font-size: .85rem;
            }

        .hist-scroll {
            max-height: 480px;
            overflow-y: auto;
            overflow-x: auto;
        }

            .hist-scroll::-webkit-scrollbar {
                width: 5px;
                height: 5px;
            }

            .hist-scroll::-webkit-scrollbar-track {
                background: #f8fafc;
            }

            .hist-scroll::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

                .hist-scroll::-webkit-scrollbar-thumb:hover {
                    background: #94a3b8;
                }

            .hist-scroll .hist-table thead {
                position: sticky;
                top: 0;
                z-index: 2;
                background: #fff;
                box-shadow: 0 1px 0 #e2e8f0;
            }

        .status-cancelled {
            background: #fee2e2 !important;
            color: #dc2626 !important;
        }

        .meta-branch {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: .72rem;
            font-weight: 600;
            color: #0369a1;
            background: #e0f2fe;
            padding: 1px 7px;
            border-radius: 20px;
        }

            .meta-branch i {
                font-size: .6rem;
            }
    </style>
}

@section Scripts {
    <script>
        function applyFilters() {
            var branch = (document.getElementById("gBranch")  || { value: "" }).value;
            var ojt    = (document.getElementById("gOJT")     || { value: "" }).value;

            ["appTable", "canTable"].forEach(function(tableId) {
                document.querySelectorAll("#" + tableId + " tbody tr").forEach(function(row) {
                    var show = (!branch || row.dataset.branch === branch) &&
                               (!ojt    || row.dataset.ojt    === ojt);
                    row.classList.toggle("hist-row-hidden", !show);
                });
            });
        }

        function clearFilters() {
            var fb = document.getElementById("gBranch");
            var fo = document.getElementById("gOJT");
            if (fb) fb.value = "";
            if (fo) fo.value = "";
            applyFilters();
        }
    </script>
}
