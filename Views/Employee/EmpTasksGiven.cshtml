                font-size: .65rem;
            }

        .hf-controls {
            display: flex;
            align-items: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .hf-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .hf-label {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .hf-label i {
                font-size: .6rem;
                color: #2563ab;
            }

        .hf-select {
            height: 34px;
            padding: 0 10px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #1e293b;
            font-size: .82rem;
            cursor: pointer;
            outline: none;
            min-width: 150px;
            transition: border-color .15s;
        }

            .hf-select:focus {
                border-color: #2563ab;
            }

        .hf-clear {
            height: 34px;
            padding: 0 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #64748b;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all .15s;
            align-self: flex-end;
        }

            .hf-clear:hover {
                border-color: #94a3b8;
                background: #f1f5f9;
                color: #1e293b;
            }

        .emp-row-hidden {
            display: none !important;
        }

        .meta-branch {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: .72rem;
            font-weight: 600;
            color: #0369a1;
            background: #e0f2fe;
            padding: 1px 7px;
            border-radius: 20px;
        }

            .meta-branch i {
                font-size: .6rem;
            }

        /* ── Pagination ── */
        .pg-wrap {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px;
            padding: 12px 4px 2px;
            border-top: 1px solid #f1f5f9;
            margin-top: 4px;
        }

        .pg-info {
            font-size: .78rem;
            color: #94a3b8;
            font-weight: 500;
        }

        .pg-btns {
            display: flex;
            align-items: center;
            gap: 4px;
            flex-wrap: wrap;
        }

        .pg-btn {
            min-width: 32px;
            height: 32px;
            padding: 0 10px;
            border: 1px solid #e2e8f0;
            border-radius: 7px;
            background: #fff;
            color: #475569;
            font-size: .78rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
        }

            .pg-btn:hover:not(:disabled) {
                border-color: #2563ab;
                color: #2563ab;
                background: #eff6ff;
            }

            .pg-btn.active {
                background: #2563ab;
                color: #fff;
                border-color: #2563ab;
            }

            .pg-btn:disabled {
                opacity: .4;
                cursor: not-allowed;
            }

            .pg-btn.pg-prev, .pg-btn.pg-next {
                gap: 4px;
            }
    </style>
}

@section Scripts {

    <script>

        function applyFilters() {
            var branch = (document.getElementById("filterBranch") || { value: "" }).value;
            var ojt    = (document.getElementById("filterOJT")    || { value: "" }).value;
            document.querySelectorAll(".emp-task-table tbody tr[data-branch]").forEach(function(row) {
                var show = (!branch || row.dataset.branch === branch) &&
                           (!ojt    || row.dataset.ojt    === ojt);
                row.classList.toggle("emp-row-hidden", !show);
            });
        }
        function clearFilters() {
            var fb = document.getElementById("filterBranch");
            var fo = document.getElementById("filterOJT");
            if (fb) fb.value = "";
            if (fo) fo.value = "";
            applyFilters();
        }


        // ── Pagination ──
        var PG_SIZE = 10;
        var pgCurrent = 1;

        function pgInit() {
            var rows = Array.from(document.querySelectorAll('.emp-task-table tbody tr:not(.emp-row-hidden)'));
            pgRender(rows);
        }

        function pgRender(allRows) {
            var total = allRows.length;
            var pages = Math.max(1, Math.ceil(total / PG_SIZE));
            if (pgCurrent > pages) pgCurrent = pages;
            var start = (pgCurrent - 1) * PG_SIZE;
            var end   = start + PG_SIZE;

            allRows.forEach(function(r, i) { r.style.display = (i >= start && i < end) ? '' : 'none'; });

            var wrap = document.getElementById('pgWrap');
            if (!wrap) return;
            if (total <= PG_SIZE) { wrap.innerHTML = ''; return; }

            var info = '<span class="pg-info">Showing ' + (start+1) + '–' + Math.min(end, total) + ' of ' + total + '</span>';

            var btns = '<div class="pg-btns">';
            btns += '<button class="pg-btn pg-prev" onclick="pgGo(' + (pgCurrent-1) + ')" ' + (pgCurrent===1?'disabled':'') + '><i class="fas fa-chevron-left"></i></button>';

            // page number buttons — show max 5 around current
            var lo = Math.max(1, pgCurrent - 2), hi = Math.min(pages, pgCurrent + 2);
            if (lo > 1) btns += '<button class="pg-btn" onclick="pgGo(1)">1</button>' + (lo > 2 ? '<span class="pg-btn" style="cursor:default;border:none;">…</span>' : '');
            for (var p = lo; p <= hi; p++) {
                btns += '<button class="pg-btn' + (p===pgCurrent?' active':'') + '" onclick="pgGo(' + p + ')">' + p + '</button>';
            }
            if (hi < pages) btns += (hi < pages-1 ? '<span class="pg-btn" style="cursor:default;border:none;">…</span>' : '') + '<button class="pg-btn" onclick="pgGo(' + pages + ')">' + pages + '</button>';
            btns += '<button class="pg-btn pg-next" onclick="pgGo(' + (pgCurrent+1) + ')" ' + (pgCurrent===pages?'disabled':'') + '><i class="fas fa-chevron-right"></i></button>';
            btns += '</div>';

            wrap.innerHTML = info + btns;
        }

        function pgGo(page) {
            pgCurrent = page;
            var rows = Array.from(document.querySelectorAll('.emp-task-table tbody tr:not(.emp-row-hidden)'));
            pgRender(rows);
        }

        // Re-run pagination after filters change
        var _origApply = window.applyFilters;
        window.applyFilters = function() {
            if (_origApply) _origApply();
            pgCurrent = 1;
            setTimeout(function() {
                var rows = Array.from(document.querySelectorAll('.emp-task-table tbody tr:not(.emp-row-hidden)'));
                pgRender(rows);
            }, 0);
        };

        document.addEventListener('DOMContentLoaded', function() { pgInit(); });

        function openCancelModal(taskId, taskTitle) {
            document.getElementById('cancelTaskId').value  = taskId;
            document.getElementById('cancelTaskName').textContent = '"' + taskTitle + '"';
            var overlay = document.getElementById('cancelOverlay');
            overlay.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        function closeCancelModal() {
            document.getElementById('cancelOverlay').style.display = 'none';
            document.body.style.overflow = '';
        }
        function confirmCancel() {
            document.getElementById('cancelTaskForm').submit();
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeCancelModal();
        });
    </script>
}
