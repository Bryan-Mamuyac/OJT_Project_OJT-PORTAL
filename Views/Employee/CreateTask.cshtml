@model CreateTaskViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Create Task";
    var allOjts = ViewBag.OJTs as List<ITPMS_OJT.Models.User> ?? new();
    var branches = ViewBag.Branches as string[] ?? new[] { "Agoo", "Reina Mercedes", "Candon", "Pasig" };
    string defBranch = (ViewBag.DefaultBranch as string ?? "").Trim();

    // Build branchOjts as a plain JSON string — no Razor inside <script>
    var branchMap = new System.Collections.Generic.Dictionary<string, object>();
    foreach (var b in branches)
    {
        var list = allOjts
            .Where(o => o.Branch.Trim() == b.Trim())
            .Select(o => new { id = o.UserId, name = o.FullName })
            .ToList<object>();
        branchMap[b] = list;
    }
    string branchOjtsJson = JsonSerializer.Serialize(branchMap);
}

<div class="form-page">
    <div class="form-card">
        <div class="form-card-header">
            <h3><i class="fas fa-plus-circle"></i> Create New Task</h3>
            <p>Assign a task to an OJT trainee in your department.</p>
        </div>

        <form asp-action="CreateTask" method="post" enctype="multipart/form-data" id="createTaskForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- ===== BRANCH FILTER ===== -->
            <div class="ct-section">
                <label class="ct-label">
                    <i class="fas fa-map-marker-alt"></i> Branch
                    <span class="ct-label-hint">OJTs shown will be filtered to this branch only</span>
                </label>
                <div class="branch-pills" id="branchPills">
                    @foreach (var b in branches)
                    {
                        <button type="button"
                                class="branch-pill @(b == defBranch ? "active" : "")"
                                data-branch="@b"
                                onclick="selectBranch('@b')">
                            <i class="fas fa-map-marker-alt"></i> @b
                        </button>
                    }
                </div>
                <input type="hidden" name="SelectedBranch" id="selectedBranchInput" value="@defBranch" />

                <!-- Branch summary banner -->
                <div class="branch-banner" id="branchBanner">
                    <i class="fas fa-info-circle"></i>
                    <span id="branchBannerText"></span>
                </div>
            </div>

            <!-- ===== TASK TYPE ===== -->
            <div class="ct-section">
                <span class="ct-label"><i class="fas fa-layer-group"></i> Task Type</span>
                <div class="task-type-grid">

                    <div class="type-card active" id="cardIndividual" onclick="selectType('Individual')">
                        <input type="radio" name="TaskType" value="Individual" id="radioIndividual" checked />
                        <div class="tc-left">
                            <div class="tc-icon-wrap">
                                <i class="fas fa-user tc-icon"></i>
                            </div>
                            <div class="tc-text">
                                <strong>Individual</strong>
                                <small>Assign to one OJT trainee</small>
                            </div>
                        </div>
                        <i class="fas fa-check-circle tc-check"></i>
                    </div>

                    <div class="type-card" id="cardGroup" onclick="selectType('Group')">
                        <input type="radio" name="TaskType" value="Group" id="radioGroup" />
                        <div class="tc-left">
                            <div class="tc-icon-wrap">
                                <i class="fas fa-users tc-icon"></i>
                            </div>
                            <div class="tc-text">
                                <strong>Group</strong>
                                <small>Send to all OJTs in selected branch</small>
                            </div>
                        </div>
                        <i class="fas fa-check-circle tc-check"></i>
                    </div>

                </div>
            </div>

            <!-- ===== ASSIGN TO ===== -->
            <div id="assignToSection" class="ct-section">
                <label class="ct-label" asp-for="AssignedToUserId">
                    <i class="fas fa-user-graduate"></i> Assign To
                </label>
                <select asp-for="AssignedToUserId" class="form-control" id="assignToSelect">
                    <option value="">-- Select OJT Trainee --</option>
                </select>

                <span asp-validation-for="AssignedToUserId" class="field-error"></span>
            </div>

            <!-- Group notice -->
            <div id="groupNotice" class="group-notice ct-section-flat" style="display:none;">
                <i class="fas fa-info-circle"></i>
                <div>
                    <strong>Group Task</strong> — This task will be sent to
                    <strong id="groupCount">0</strong> OJT trainee(s) in the
                    <strong id="groupBranchName">@defBranch</strong> branch.
                    Each trainee submits separately.
                </div>
            </div>

            <!-- ===== TITLE ===== -->
            <div class="ct-section">
                <label class="ct-label" asp-for="Title"><i class="fas fa-heading"></i> Task Title</label>
                <input asp-for="Title" class="form-control" placeholder="Enter task title" />
                <span asp-validation-for="Title" class="field-error"></span>
            </div>

            <!-- ===== DESCRIPTION ===== -->
            <div class="ct-section">
                <label class="ct-label" asp-for="Description"><i class="fas fa-align-left"></i> Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="Describe the task requirements, deliverables, and any relevant context..."></textarea>
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <!-- ===== DEADLINE ===== -->
            <div class="ct-section">
                <span class="ct-label">
                    <i class="fas fa-calendar-alt"></i> Deadline <span class="required-star">*</span>
                </span>
                <div class="deadline-row">
                    <div class="dl-col dl-col-date">
                        <span class="dl-sub">Date</span>
                        <input type="date" name="DeadlineDate" class="form-control"
                               id="deadlineDate"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               onchange="updatePreview()" />
                    </div>
                    <div class="dl-col dl-col-ampm">
                        <span class="dl-sub">Period</span>
                        <div class="ampm-toggle">
                            <button type="button" class="ampm-btn active" id="btnAM" onclick="setAmPm('AM')">AM</button>
                            <button type="button" class="ampm-btn" id="btnPM" onclick="setAmPm('PM')">PM</button>
                        </div>
                        <input type="hidden" name="DeadlineAmPm" id="deadlineAmPm" value="AM" />
                    </div>
                    <div class="dl-col dl-col-time">
                        <span class="dl-sub">Time</span>
                        <select name="DeadlineTime" class="form-control" id="deadlineTime" onchange="updatePreview()">
                            <option value="">-- Select --</option>
                        </select>
                    </div>
                </div>
                <span id="deadlineDateError" class="field-error" style="display:none;">Deadline date is required.</span>
                <span id="deadlineTimeError" class="field-error" style="display:none;">Deadline time is required.</span>
                <span asp-validation-for="DeadlineDate" class="field-error"></span>
                <span asp-validation-for="DeadlineTime" class="field-error"></span>
                <div id="deadlinePreview" class="deadline-preview" style="display:none;">
                    <i class="fas fa-clock"></i>
                    <span id="deadlinePreviewText"></span>
                </div>
            </div>

            <!-- ===== FILES ===== -->
            <div class="ct-section">
                <label class="ct-label">
                    <i class="fas fa-file-upload"></i> Attach Reference Files
                    <span class="optional">(Optional — up to 5 files)</span>
                </label>
                <div class="mfu-area" id="fileArea">
                    <input name="AttachedFiles" type="file" id="fileInput"
                           accept=".pdf,.xlsx,.xls,.docx,.doc,.pptx,.ppt,.png,.jpg,.jpeg,.pbix,.zip"
                           multiple style="display:none" />
                    <div class="mfu-prompt" id="filePrompt" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Drag & drop or <strong>click to browse</strong></p>
                        <small>PDF · Excel · Word · PowerPoint · PNG · JPG · Power BI · ZIP</small>
                    </div>
                    <div class="mfu-list" id="fileList"></div>
                    <div class="mfu-add" id="mfuAddBtn" style="display:none" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-plus"></i> Add another file
                    </div>
                </div>
                <span class="field-error" id="fileError"></span>
            </div>

            <!-- ===== ACTIONS ===== -->
            <div class="ct-actions">
                <a asp-action="Index" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="fas fa-paper-plane"></i>
                    <span id="submitLabel">Assign Task</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .ct-section {
            padding: 16px 24px;
        }

        .ct-section-flat {
            padding: 0 24px 16px;
        }

        .ct-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #475569;
            margin-bottom: 10px;
        }

            .ct-label i {
                color: #2563ab;
            }

        .ct-label-hint {
            font-size: .7rem;
            font-weight: 500;
            letter-spacing: 0;
            text-transform: none;
            color: #94a3b8;
            margin-left: 4px;
        }

        .ct-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 16px 24px;
            border-top: 1px solid #e2e8f0;
            background: #f8fafc;
        }

        /* ── Branch pills ── */
        .branch-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }

        .branch-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 20px;
            border: 2px solid #e2e8f0;
            background: #f8fafc;
            color: #475569;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .18s;
        }

            .branch-pill i {
                font-size: .72rem;
            }

            .branch-pill:hover {
                border-color: #93c5fd;
                background: #eff6ff;
                color: #1d4ed8;
            }

            .branch-pill.active {
                border-color: #2563ab;
                background: #2563ab;
                color: #fff;
                box-shadow: 0 2px 8px rgba(37,99,171,.25);
            }

                .branch-pill.active i {
                    color: #fff;
                }

        /* Branch info banner */
        .branch-banner {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 14px;
            border-radius: 8px;
            background: #f0f9ff;
            border: 1px solid #bae6fd;
            font-size: .82rem;
            color: #0369a1;
            font-weight: 500;
            margin-top: 4px;
        }

            .branch-banner i {
                flex-shrink: 0;
            }

            .branch-banner.warn {
                background: #fff7ed;
                border-color: #fed7aa;
                color: #c2410c;
            }

        /* ── Task type grid ── */
        .task-type-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .type-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 16px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            cursor: pointer;
            background: #f8fafc;
            transition: border-color .2s, background .2s, box-shadow .2s;
            user-select: none;
        }

            .type-card:hover {
                border-color: #93c5fd;
                background: #f0f7ff;
            }

            .type-card.active {
                border-color: #2563ab;
                background: #eff6ff;
                box-shadow: 0 0 0 3px rgba(37,99,171,.13);
            }

            .type-card input[type=radio] {
                display: none;
            }

        .tc-left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex: 1;
        }

        .tc-icon-wrap {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #dbeafe;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background .2s;
        }

        .type-card.active .tc-icon-wrap {
            background: #2563ab;
        }

        .tc-icon {
            font-size: 1rem;
            color: #2563ab;
            transition: color .2s;
        }

        .type-card.active .tc-icon {
            color: #fff;
        }

        .tc-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

            .tc-text strong {
                font-size: .9rem;
                color: #0f172a;
            }

            .tc-text small {
                font-size: .75rem;
                color: #64748b;
            }

        .tc-check {
            font-size: 1rem;
            color: #2563ab;
            opacity: 0;
            transition: opacity .2s;
            flex-shrink: 0;
        }

        .type-card.active .tc-check {
            opacity: 1;
        }

        /* ── Group notice ── */
        .group-notice {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            padding: 12px 14px;
            font-size: .875rem;
            color: #1e40af;
            margin: 0 24px 16px;
        }

            .group-notice i {
                font-size: 1rem;
                margin-top: 1px;
                flex-shrink: 0;
            }

        /* ── Deadline ── */
        .deadline-row {
            display: flex;
            gap: 10px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .dl-col {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .dl-col-date {
            flex: 0 0 175px;
        }

        .dl-col-ampm {
            flex: 0 0 auto;
        }

        .dl-col-time {
            flex: 1;
            min-width: 130px;
        }

        .dl-sub {
            font-size: .7rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .ampm-toggle {
            display: flex;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            overflow: hidden;
            height: 42px;
        }

        .ampm-btn {
            padding: 0 20px;
            border: none;
            background: #f8fafc;
            cursor: pointer;
            font-size: .875rem;
            font-weight: 700;
            color: #64748b;
            transition: background .15s,color .15s;
        }

            .ampm-btn + .ampm-btn {
                border-left: 1px solid #cbd5e1;
            }

            .ampm-btn.active {
                background: #1a3a5c;
                color: #fff;
            }

            .ampm-btn:hover:not(.active) {
                background: #e2e8f0;
                color: #1a3a5c;
            }

        .deadline-preview {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
            padding: 8px 14px;
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            font-size: .875rem;
            color: #15803d;
            font-weight: 600;
        }


        /* ── Multi-file upload ── */
        .mfu-area {
            border: 2px dashed #cbd5e1;
            border-radius: 12px;
            background: #f8fafc;
            transition: border-color .2s;
        }

            .mfu-area.drag-over {
                border-color: #2563ab;
                background: #eff6ff;
            }

        .mfu-prompt {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 28px 20px;
            cursor: pointer;
            text-align: center;
            gap: 4px;
        }

            .mfu-prompt i {
                font-size: 2rem;
                color: #93c5fd;
                margin-bottom: 4px;
            }

            .mfu-prompt p {
                margin: 0;
                font-size: .875rem;
                color: #475569;
            }

            .mfu-prompt small {
                color: #94a3b8;
                font-size: .72rem;
            }

        .mfu-list {
            padding: 4px 10px 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .mfu-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: .82rem;
            color: #334155;
        }

            .mfu-chip i.mfu-icon {
                font-size: .95rem;
                flex-shrink: 0;
            }

            .mfu-chip .mfu-name {
                flex: 1;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .mfu-chip .mfu-size {
                font-size: .72rem;
                color: #94a3b8;
                flex-shrink: 0;
            }

            .mfu-chip .mfu-remove {
                background: none;
                border: none;
                cursor: pointer;
                color: #94a3b8;
                font-size: .9rem;
                padding: 2px 4px;
                border-radius: 4px;
                transition: color .15s, background .15s;
                flex-shrink: 0;
                display: flex;
                align-items: center;
            }

                .mfu-chip .mfu-remove:hover {
                    color: #dc2626;
                    background: #fee2e2;
                }

        .mfu-add {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 10px 14px;
            cursor: pointer;
            font-size: .8rem;
            font-weight: 600;
            color: #2563ab;
            border-top: 1px dashed #e2e8f0;
            margin-top: 4px;
            transition: background .15s;
            border-radius: 0 0 10px 10px;
        }

            .mfu-add:hover {
                background: #eff6ff;
            }

            .mfu-add i {
                font-size: .75rem;
            }

        @@media (max-width:560px) {
            .task-type-grid {
                grid-template-columns: 1fr;
            }

            .deadline-row {
                flex-direction: column;
            }

            .dl-col-date, .dl-col-time {
                flex: none;
                width: 100%;
            }

            .branch-pills {
                gap: 6px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        const branchOjts = @Html.Raw(branchOjtsJson);
        const defaultBranch = "@defBranch";

        let currentBranch = defaultBranch;
        let currentType   = "Individual";

        function selectBranch(branch) {
            currentBranch = branch;
            document.getElementById("selectedBranchInput").value = branch;
            document.querySelectorAll(".branch-pill").forEach(function(p) {
                p.classList.toggle("active", p.dataset.branch === branch);
            });
            rebuildSelect();
            updateBanner();
            updateGroupNotice();
        }

        function rebuildSelect() {
            var ojts = branchOjts[currentBranch] || [];
            var sel  = document.getElementById("assignToSelect");
            sel.innerHTML = '<option value="">-- Select OJT Trainee --</option>';
            ojts.forEach(function(o) {
                var opt = document.createElement("option");
                opt.value = o.id;
                opt.textContent = o.name;
                sel.appendChild(opt);
            });
            document.getElementById("submitBtn").disabled = (ojts.length === 0 && currentType === "Individual");
        }

        function updateBanner() {
            var count  = (branchOjts[currentBranch] || []).length;
            var banner = document.getElementById("branchBanner");
            var text   = document.getElementById("branchBannerText");
            if (count === 0) {
                banner.className = "branch-banner warn";
                text.textContent = "No active OJT trainees in " + currentBranch + ".";
            } else {
                banner.className = "branch-banner";
                text.textContent = count + " active OJT trainee(s) available in " + currentBranch + ".";
            }
        }

        function updateGroupNotice() {
            var count = (branchOjts[currentBranch] || []).length;
            document.getElementById("groupCount").textContent      = count;
            document.getElementById("groupBranchName").textContent = currentBranch;
            document.getElementById("submitLabel").textContent =
                currentType === "Group" ? "Assign to All " + count + " OJT(s)" : "Assign Task";
        }

        function selectType(type) {
            currentType = type;
            var isGroup = type === "Group";
            document.getElementById("cardIndividual").classList.toggle("active", !isGroup);
            document.getElementById("cardGroup").classList.toggle("active", isGroup);
            document.getElementById("radioIndividual").checked = !isGroup;
            document.getElementById("radioGroup").checked      =  isGroup;
            document.getElementById("assignToSection").style.display = isGroup ? "none"  : "block";
            document.getElementById("groupNotice").style.display     = isGroup ? "flex"  : "none";
            if (isGroup) document.getElementById("assignToSelect").value = "";
            updateGroupNotice();
        }

        var AM_SLOTS = [
            ["08:00","8:00 AM"],["08:30","8:30 AM"],["09:00","9:00 AM"],["09:30","9:30 AM"],
            ["10:00","10:00 AM"],["10:30","10:30 AM"],["11:00","11:00 AM"],["11:30","11:30 AM"],["12:00","12:00 PM"]
        ];
        var PM_SLOTS = [
            ["01:00","1:00 PM"],["01:30","1:30 PM"],["02:00","2:00 PM"],["02:30","2:30 PM"],
            ["03:00","3:00 PM"],["03:30","3:30 PM"],["04:00","4:00 PM"],["04:30","4:30 PM"],["05:00","5:00 PM"]
        ];

        function populateTimes() {
            var ampm  = document.getElementById("deadlineAmPm").value;
            var sel   = document.getElementById("deadlineTime");
            var slots = ampm === "AM" ? AM_SLOTS : PM_SLOTS;
            sel.innerHTML = '<option value="">-- Select time --</option>';
            slots.forEach(function(s) {
                var o = document.createElement("option");
                o.value = s[0]; o.textContent = s[1];
                sel.appendChild(o);
            });
            updatePreview();
        }

        function setAmPm(val) {
            document.getElementById("deadlineAmPm").value = val;
            document.getElementById("btnAM").classList.toggle("active", val === "AM");
            document.getElementById("btnPM").classList.toggle("active", val === "PM");
            populateTimes();
        }

        function updatePreview() {
            var date = document.getElementById("deadlineDate").value;
            var time = document.getElementById("deadlineTime").value;
            var ampm = document.getElementById("deadlineAmPm").value;
            var prev = document.getElementById("deadlinePreview");
            if (date && time) {
                var parts  = date.split("-");
                var months = ["January","February","March","April","May","June",
                              "July","August","September","October","November","December"];
                var tp = time.split(":");
                document.getElementById("deadlinePreviewText").textContent =
                    months[parseInt(parts[1])-1] + " " + parseInt(parts[2]) + ", " + parts[0] +
                    "  \u2014  " + parseInt(tp[0]) + ":" + tp[1] + " " + ampm;
                prev.style.display = "flex";
            } else {
                prev.style.display = "none";
            }
        }

        // ── Multi-file upload ──
        var mfuFiles = []; // array of File objects
        var MFU_MAX  = 5;
        var MFU_ALLOWED = [".pdf",".xlsx",".xls",".docx",".doc",".pptx",".ppt",".png",".jpg",".jpeg",".pbix",".zip"];

        function mfuIcon(name) {
            var ext = name.substring(name.lastIndexOf(".")).toLowerCase();
            if ([".png",".jpg",".jpeg"].includes(ext)) return "fas fa-image" ;
            if (ext === ".pbix")  return "fas fa-chart-bar";
            if (ext === ".pdf")   return "fas fa-file-pdf";
            if ([".xlsx",".xls"].includes(ext)) return "fas fa-file-excel";
            if ([".docx",".doc"].includes(ext)) return "fas fa-file-word";
            if ([".pptx",".ppt"].includes(ext)) return "fas fa-file-powerpoint";
            return "fas fa-file";
        }
        function mfuSize(bytes) {
            if (bytes < 1024) return bytes + " B";
            if (bytes < 1048576) return (bytes/1024).toFixed(1) + " KB";
            return (bytes/1048576).toFixed(1) + " MB";
        }
        function mfuRender() {
            var list  = document.getElementById("fileList");
            var prompt= document.getElementById("filePrompt");
            var addBtn= document.getElementById("mfuAddBtn");
            var err   = document.getElementById("fileError");
            list.innerHTML = "";
            if (mfuFiles.length === 0) {
                prompt.style.display = "flex"; addBtn.style.display = "none";
            } else {
                prompt.style.display = "none";
                addBtn.style.display = mfuFiles.length < MFU_MAX ? "flex" : "none";
                mfuFiles.forEach(function(f, i) {
                    var chip = document.createElement("div");
                    chip.className = "mfu-chip";
                    chip.innerHTML = '<i class="mfu-icon ' + mfuIcon(f.name) + '"></i>' +
                        '<span class="mfu-name" title="' + f.name + '">' + f.name + '</span>' +
                        '<span class="mfu-size">' + mfuSize(f.size) + '</span>' +
                        '<button type="button" class="mfu-remove" onclick="mfuRemove(' + i + ')" title="Remove"><i class="fas fa-times"></i></button>';
                    list.appendChild(chip);
                });
            }
            err.textContent = "";
            mfuSyncInput();
        }
        function mfuSyncInput() {
            // Rebuild a DataTransfer so the real <input> carries all files for form submission
            var dt = new DataTransfer();
            mfuFiles.forEach(function(f) { dt.items.add(f); });
            document.getElementById("fileInput").files = dt.files;
        }
        function mfuAdd(fileList) {
            var err = document.getElementById("fileError");
            var arr = Array.from(fileList);
            for (var i = 0; i < arr.length; i++) {
                var f   = arr[i];
                var ext = f.name.substring(f.name.lastIndexOf(".")).toLowerCase();
                if (!MFU_ALLOWED.includes(ext)) { err.textContent = '"' + f.name + '" is not an allowed file type.'; continue; }
                if (mfuFiles.length >= MFU_MAX)  { err.textContent = "Maximum " + MFU_MAX + " files allowed."; break; }
                if (mfuFiles.some(function(x){ return x.name === f.name && x.size === f.size; })) continue; // dup
                mfuFiles.push(f);
            }
            document.getElementById("fileInput").value = ""; // reset so same file can re-trigger change
            mfuRender();
        }
        function mfuRemove(idx) {
            mfuFiles.splice(idx, 1);
            mfuRender();
        }

        document.getElementById("fileInput").addEventListener("change", function() {
            if (this.files.length) mfuAdd(this.files);
        });

        var area = document.getElementById("fileArea");
        area.addEventListener("dragover", function(e) { e.preventDefault(); area.classList.add("drag-over"); });
        area.addEventListener("dragleave", function() { area.classList.remove("drag-over"); });
        area.addEventListener("drop", function(e) {
            e.preventDefault(); area.classList.remove("drag-over");
            if (e.dataTransfer.files.length) mfuAdd(e.dataTransfer.files);
        });

        document.getElementById("createTaskForm").addEventListener("submit", function(e) {
            var date    = document.getElementById("deadlineDate").value;
            var time    = document.getElementById("deadlineTime").value;
            var dateErr = document.getElementById("deadlineDateError");
            var timeErr = document.getElementById("deadlineTimeError");
            var hasError = false;
            if (!date) { dateErr.style.display = "block"; document.getElementById("deadlineDate").classList.add("input-error"); hasError = true; }
            else        { dateErr.style.display = "none";  document.getElementById("deadlineDate").classList.remove("input-error"); }
            if (!time) { timeErr.style.display = "block"; document.getElementById("deadlineTime").classList.add("input-error"); hasError = true; }
            else        { timeErr.style.display = "none";  document.getElementById("deadlineTime").classList.remove("input-error"); }
            if (hasError) { e.preventDefault(); document.getElementById("deadlineDate").scrollIntoView({ behavior:"smooth", block:"center" }); }
        });

        document.getElementById("deadlineDate").addEventListener("change", function() {
            if (this.value) { this.classList.remove("input-error"); document.getElementById("deadlineDateError").style.display = "none"; }
        });
        document.getElementById("deadlineTime").addEventListener("change", function() {
            if (this.value) { this.classList.remove("input-error"); document.getElementById("deadlineTimeError").style.display = "none"; }
        });

        populateTimes();
        selectBranch(defaultBranch);
    </script>
}
