@functions {
    string FormatConvTime(DateTime dt)
    {
        var now = DateTime.Now;
        if (dt.Date == now.Date) return dt.ToString("h:mm tt");
        if (dt.Date == now.Date.AddDays(-1)) return "Yesterday";
        return dt.ToString("MMM dd");
    }
}
@{
    ViewData["Title"] = "My Chat";
    var convos = ViewBag.Conversations as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var openConvId = (int)(ViewBag.OpenConvId ?? 0);
    var myId = (int)(ViewBag.MyId ?? 0);
    var myRole = ViewBag.MyRole as string ?? "";
    var myName = ViewBag.MyName as string ?? "";
    var emptyStyle = openConvId > 0 ? "display:none" : "";
    var activeStyle = openConvId > 0 ? "" : "display:none";
}

<div class="cx-shell">
    <div class="cx-sidebar" id="chatLeft">
        <div class="cx-sidebar-top">
            <div class="cx-sidebar-title"><i class="fas fa-comments"></i><span>Messages</span></div>
            <button class="cx-compose-btn" id="newChatBtn" title="New conversation"><i class="fas fa-edit"></i></button>
        </div>
        <div class="cx-search-wrap">
            <i class="fas fa-search"></i>
            <input id="chatSearch" type="text" placeholder="Search conversations..." autocomplete="off" />
        </div>
        <div class="cx-conv-list" id="chatConvList">
            @if (!convos.Any())
            {
                <div class="cx-conv-empty">
                    <i class="fas fa-comment-dots"></i>
                    <p>No conversations yet</p>
                    <span>Tap the edit icon above to start</span>
                </div>
            }
            else
            {
                foreach (var c in convos)
                {
                    string? rawMsg = c.LastMessage as string;
                    string? rawFile = c.LastFile as string;
                    string? rawPic = c.OtherPic as string;
                    string lastMsg = !string.IsNullOrEmpty(rawMsg)
                    ? (rawMsg.Length > 38 ? rawMsg[..38] + "..." : rawMsg)
                    : (!string.IsNullOrEmpty(rawFile) ? "Attachment" : "No messages yet");
                    string timeStr = c.LastSentAt != null ? FormatConvTime((DateTime)c.LastSentAt) : "";
                    int unread = (int)c.UnreadCount;
                    string pic = !string.IsNullOrEmpty(rawPic) ? "/uploads/profiles/" + rawPic : "";
                    string otherName = (string)c.OtherName;
                    string otherRole = (string)c.OtherRole;
                    string[] np = otherName.Split(' ');
                    string initials = np.Length > 1 ? "" + np[0][0] + np[1][0] : otherName[..1];
                    string cls = "cx-conv-item" + (c.ConversationId == openConvId ? " active" : "") + (unread > 0 ? " unread" : "");
                    string avBg = string.IsNullOrEmpty(pic) ? "" : "background:transparent";
                    <div class="@cls"
                         data-conv-id="@c.ConversationId"
                         data-other-id="@c.OtherId"
                         data-other-name="@otherName"
                         data-other-role="@otherRole"
                         data-other-dept="@c.OtherDept"
                         data-other-branch="@c.OtherBranch"
                         data-other-pic="@pic"
                         onclick="openConv(@c.ConversationId, this)">
                        <div class="cx-conv-av" style="@avBg">
                            @if (!string.IsNullOrEmpty(pic))
                            {
                                <img src="@pic" alt="@otherName" />
                            }
                            else
                            {

                                <span>@initials.ToUpper()</span>
                            }
                            <span class="cx-role-pip cx-role-@otherRole.ToLower()"></span>
                        </div>
                        <div class="cx-conv-info">
                            <div class="cx-conv-row1">
                                <span class="cx-conv-name">@otherName</span>
                                <span class="cx-conv-ts">@timeStr</span>
                            </div>
                            <div class="cx-conv-row2">
                                <span class="cx-conv-prev">@lastMsg</span>
                                @if (unread > 0)
                                {
                                    <span class="cx-unread-dot">@unread</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="cx-main" id="chatRight">
        <div class="cx-empty" id="chatEmptyState" style="@emptyStyle">
            <div class="cx-empty-icon"><i class="fas fa-comments"></i></div>
            <h3>Your Messages</h3>
            <p>Select a conversation or start a new one</p>
            <button class="cx-start-btn" onclick="document.getElementById('newChatBtn').click()">
                <i class="fas fa-edit"></i> New Conversation
            </button>
        </div>
        <div class="cx-convo" id="chatActive" style="@activeStyle">
            <div class="cx-hdr">
                <button class="cx-back-btn" onclick="showLeftOnMobile()"><i class="fas fa-arrow-left"></i></button>
                <div class="cx-hdr-av" id="chatHdrAvatar"></div>
                <div class="cx-hdr-info">
                    <div class="cx-hdr-name" id="chatHdrName">--</div>
                    <div class="cx-hdr-meta" id="chatHdrMeta"></div>
                </div>
            </div>
            <div class="cx-msgs" id="chatMessages">
                <div class="cx-loading"><div class="cx-spinner"></div></div>
            </div>
            <div class="cx-input-bar">
                <div class="cx-file-preview" id="chatFilePreview" style="display:none">
                    <div class="cx-file-chip">
                        <i class="fas fa-paperclip" id="chatFileChipIcon"></i>
                        <span id="chatFileChipName"></span>
                        <button onclick="clearFile()"><i class="fas fa-times"></i></button>
                    </div>
                </div>
                <div class="cx-input-row">
                    <button class="cx-attach-btn" onclick="document.getElementById('chatFileInput').click()" title="Attach">
                        <i class="fas fa-paperclip"></i>
                    </button>
                    <input type="file" id="chatFileInput" style="display:none"
                           accept=".png,.jpg,.jpeg,.pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.pbix,.zip"
                           onchange="onFileSelected(this)" />
                    <textarea id="chatMsgInput" class="cx-textarea" placeholder="Type a message..." rows="1"
                              oninput="autoGrow(this);updateCharCount(this);" maxlength="500"></textarea>
                    <span class="cx-char-count" id="charCount">500</span>
                    <button class="cx-send-btn" id="chatSendBtn" onclick="sendMessage()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- NEW CHAT MODAL -->
<div class="cx-modal-bg" id="newChatModal" style="display:none">
    <div class="cx-modal">
        <div class="cx-modal-hdr">
            <span><i class="fas fa-user-plus"></i> New Conversation</span>
            <button onclick="closeNewChatModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="cx-modal-filters">
            <input id="pickSearch" type="text" placeholder="Search by name..." oninput="filterPeople()" class="cx-search-full" />
            <select id="pickRole" onchange="loadPeople()">
                <option value="">All Roles</option>
                <option value="Employee">Employee</option>
                <option value="OJT">OJT</option>
            </select>
            <select id="pickBranch" onchange="loadPeople()">
                <option value="">All Branches</option>
                <option value="Agoo">Agoo</option>
                <option value="Reina Mercedes">Reina Mercedes</option>
                <option value="Candon">Candon</option>
                <option value="Pasig">Pasig</option>
            </select>
            <select id="pickDept" onchange="loadPeople()">
                <option value="">All Departments</option>
                <option value="IT">IT</option>
                <option value="HR">HR</option>
                <option value="Finance">Finance</option>
                <option value="Operations">Operations</option>
                <option value="Marketing">Marketing</option>
                <option value="Legal">Legal</option>
                <option value="Accounting">Accounting</option>
                <option value="Admin">Admin</option>
                <option value="Engineering">Engineering</option>
                <option value="Sales">Sales</option>
                <option value="Logistics">Logistics</option>
                <option value="Procurement">Procurement</option>
            </select>
        </div>
        <div class="cx-people-list" id="chatPeopleList">
            <div class="cx-loading"><div class="cx-spinner"></div></div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div class="cx-modal-bg" id="deleteModal" style="display:none">
    <div class="cx-modal cx-modal-sm">
        <div class="cx-modal-hdr cx-modal-hdr-danger">
            <span><i class="fas fa-trash-alt"></i> Delete Message</span>
            <button onclick="closeDeleteModal()"><i class="fas fa-times"></i></button>
        </div>
        <div class="cx-del-body">
            <p>This will permanently delete the message. This action cannot be undone.</p>
            <div class="cx-del-actions">
                <button class="cx-del-cancel" onclick="closeDeleteModal()">Cancel</button>
                <button class="cx-del-confirm" id="deleteConfirmBtn" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>
</div>

