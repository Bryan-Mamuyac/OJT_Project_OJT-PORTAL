@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function(){
            var ME           = @myId;
            var CSRF         = typeof CSRF_TOKEN !== 'undefined' ? CSRF_TOKEN : '';
            var getUrl       = '@Url.Action("GetMessages", "Chat")';
            var sendUrl      = '@Url.Action("SendMessage", "Chat")';
            var getUsersUrl  = '@Url.Action("GetUsers", "Chat")';
            var markReadUrl  = '@Url.Action("MarkRead", "Chat")';
            var getOrCreate  = '@Url.Action("GetOrCreateConversation", "Chat")';
            var getConvUrl   = '@Url.Action("GetConversation", "Chat")';
            var deleteUrl    = '@Url.Action("DeleteMessage", "Chat")';
            var indexUrl     = '@Url.Action("Index", "Chat")';

            var activeConvId  = @openConvId;
            var lastMsgId     = 0;
            var pollTimer     = null;
            var allPeople     = [];
            var selectedFile  = null;
            var lastDateLabel = '';
            var pendingDelete = 0;
            var connection    = null;
            var ALL_CONV_IDS  = [@string.Join(",", convos.Select(c => (int)c.ConversationId))];

            window.addEventListener('DOMContentLoaded', function(){
                startSignalR();
                if (activeConvId > 0) {
                    var el = document.querySelector('[data-conv-id="' + activeConvId + '"]');
                    if (el) openConv(activeConvId, el);
                    else    loadConvAndOpen(activeConvId);
                }
                document.getElementById('chatMsgInput').addEventListener('keydown', function(e){
                    if (e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); sendMessage(); }
                });
            });

            function startSignalR(){
                connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub')
                    .withAutomaticReconnect()
                    .build();

                connection.on('ReceiveMessage', function(m){
                    if (m.senderId === ME) return;
                    if (String(m.conversationId) === String(activeConvId)) {
                        var ph = document.getElementById('chatMessages').querySelector('[data-placeholder]');
                        if (ph) ph.remove();
                        appendMessage(m);
                        lastMsgId = m.messageId;
                        scrollToBottom();
                    }
                    updateConvListItem(m.conversationId, m);
                });

                connection.on('MessageDeleted', function(msgId){
                    removeMessageFromDOM(msgId);
                    // Also refresh the conv preview for both sender and receiver
                    refreshConvPreview(activeConvId);
                });

                connection.on('UnreadCountChanged', function(){
                    updateChatBadge();
                });

                connection.start().then(function(){
                    // Join ALL conversation groups so we get push updates for every convo preview
                    ALL_CONV_IDS.forEach(function(cid){ joinConvGroup(cid); });
                }).catch(function(err){
                    console.warn('SignalR unavailable, using fallback polling:', err);
                    if (activeConvId > 0)
                        pollTimer = setInterval(function(){ fetchMessages(false); }, 3000);
                });

                connection.onreconnected(function(){
                    // Re-join all groups after reconnect
                    ALL_CONV_IDS.forEach(function(cid){ joinConvGroup(cid); });
                });
            }

            function joinConvGroup(convId){
                if (connection && connection.state === signalR.HubConnectionState.Connected)
                    connection.invoke('JoinConversation', String(convId)).catch(function(e){ console.error(e); });
            }
            function leaveConvGroup(convId){
                if (connection && connection.state === signalR.HubConnectionState.Connected)
                    connection.invoke('LeaveConversation', String(convId)).catch(function(e){ console.error(e); });
            }

            window.openConv = function(convId, el){
                document.querySelectorAll('.cx-conv-item').forEach(function(i){ i.classList.remove('active'); });
                if (el) el.classList.add('active');
                if (activeConvId && activeConvId !== convId) leaveConvGroup(activeConvId);
                activeConvId  = convId;
                lastMsgId     = 0;
                lastDateLabel = '';
                clearInterval(pollTimer); pollTimer = null;
                if (el) setHeader(el.dataset.otherName, el.dataset.otherRole, el.dataset.otherDept, el.dataset.otherBranch, el.dataset.otherPic);
                document.getElementById('chatEmptyState').style.display = 'none';
                document.getElementById('chatActive').style.display     = '';
                document.getElementById('chatMessages').innerHTML       = '<div class="cx-loading"><div class="cx-spinner"></div></div>';
                document.getElementById('chatLeft').classList.add('hidden');
                joinConvGroup(convId);
                fetchMessages(true);
                if (!connection || connection.state !== signalR.HubConnectionState.Connected)
                    pollTimer = setInterval(function(){ fetchMessages(false); }, 3000);
                setTimeout(function(){ markRead(convId); }, 500);
            };

            function loadConvAndOpen(convId){
                fetch(getConvUrl + '?conversationId=' + convId + '&_=' + Date.now(), {credentials:'same-origin', cache:'no-store'})
                    .then(function(r){ return r.json(); })
                    .then(function(d){
                        setHeader(d.otherName, d.otherRole, d.otherDept, d.otherBranch, d.otherPic);
                        document.getElementById('chatEmptyState').style.display = 'none';
                        document.getElementById('chatActive').style.display     = '';
                        document.getElementById('chatMessages').innerHTML       = '<div class="cx-loading"><div class="cx-spinner"></div></div>';
                        joinConvGroup(convId);
                        fetchMessages(true);
                        if (!connection || connection.state !== signalR.HubConnectionState.Connected)
                            pollTimer = setInterval(function(){ fetchMessages(false); }, 3000);
                    });
            }

            function setHeader(name, role, dept, branch, pic){
                var av = document.getElementById('chatHdrAvatar');
                if (pic) { av.innerHTML = '<img src="' + pic + '" alt="">'; }
                else {
                    var ini = (name||'').split(' ').map(function(p){ return p[0]; }).join('').substring(0,2).toUpperCase();
                    av.innerHTML = '<span>' + ini + '</span>';
                }
                document.getElementById('chatHdrName').textContent = name || '';
                var meta = (role||'') + (dept ? ' · ' + dept : '') + (branch ? ' · ' + branch : '');
                document.getElementById('chatHdrMeta').textContent = meta;
            }

            function fetchMessages(initial){
                if (!activeConvId) return;
                fetch(getUrl + '?conversationId=' + activeConvId + '&afterId=' + lastMsgId + '&_=' + Date.now(),
                      {credentials:'same-origin', cache:'no-store'})
                    .then(function(r){ return r.json(); })
                    .then(function(msgs){
                        if (initial) { document.getElementById('chatMessages').innerHTML = ''; lastDateLabel = ''; }
                        if (msgs.length === 0 && initial) {
                            var container2 = document.getElementById('chatMessages');
                            if (!container2.querySelector('[data-placeholder]')) {
                                var ph = document.createElement('div');
                                ph.dataset.placeholder = '1';
                                ph.style.cssText = 'text-align:center;color:#94a3b8;font-size:.81rem;padding:32px;';
                                ph.textContent = 'No messages yet. Say hello!';
                                container2.appendChild(ph);
                            }
                        }
                        msgs.forEach(function(m){ appendMessage(m); });
                        if (msgs.length > 0) {
                            lastMsgId = msgs[msgs.length-1].messageId;
                            scrollToBottom();
                            updateChatBadge();
                        }
                    }).catch(function(){});
            }

            function appendMessage(m){
                var container = document.getElementById('chatMessages');
                var ph = container.querySelector('[data-placeholder]');
                if (ph) ph.remove();
                var sentDate  = new Date(m.sentAt);
                var dateLabel = sentDate.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
                if (dateLabel !== lastDateLabel) {
                    lastDateLabel = dateLabel;
                    var dd = document.createElement('div');
                    dd.className = 'cx-date-div';
                    dd.textContent = dateLabel;
                    container.appendChild(dd);
                }
                var isMine = m.senderId === ME;
                var row = document.createElement('div');
                row.className    = 'cx-msg-row' + (isMine ? ' mine' : '');
                row.dataset.msgId = m.messageId;
                var av;
                if (!isMine) {
                    av = document.createElement('div');
                    av.className = 'cx-msg-av';
                    if (m.senderPic) { av.innerHTML = '<img src="/uploads/profiles/' + m.senderPic + '" alt="">'; }
                    else { av.textContent = (m.senderName||'').split(' ').map(function(p){ return p[0]; }).join('').substring(0,2).toUpperCase(); }
                } else {
                    av = document.createElement('div');
                    av.className = 'cx-av-spacer';
                }
                var wrap = document.createElement('div');
                wrap.className = 'cx-msg-wrap';
                if (!isMine) {
                    var sn = document.createElement('div');
                    sn.className = 'cx-msg-sender';
                    sn.textContent = m.senderName || '';
                    wrap.appendChild(sn);
                }
                var bubble = document.createElement('div');
                bubble.className = 'cx-bubble';
                if (isMine) {
                    var db = document.createElement('button');
                    db.className = 'cx-delete-btn';
                    db.title     = 'Delete message';
                    db.innerHTML = '<i class="fas fa-trash-alt"></i>';
                    db.addEventListener('click', (function(mid){ return function(e){ e.stopPropagation(); openDeleteModal(mid); }; })(m.messageId));
                    bubble.appendChild(db);
                }
                if (m.body) {
                    var txt = document.createElement('span');
                    txt.textContent = m.body;
                    bubble.appendChild(txt);
                }
                if (m.attachedFilePath) {
                    if (m.fileType === 'image') {
                        var img = document.createElement('img');
                        img.src = m.attachedFilePath; img.className = 'cx-msg-img';
                        img.addEventListener('click', (function(s){ return function(){ openLightbox(s); }; })(m.attachedFilePath));
                        bubble.appendChild(img);
                    } else {
                        var a = document.createElement('a');
                        a.href = m.attachedFilePath; a.target = '_blank'; a.className = 'cx-file-link';
                        a.innerHTML = fileIcon(m.fileType) + '<span>' + (m.attachedFileName||'') + '</span>';
                        bubble.appendChild(a);
                    }
                }
                var tm = document.createElement('div');
                tm.className = 'cx-msg-time';
                tm.textContent = m.sentAtDisplay;
                wrap.appendChild(bubble);
                wrap.appendChild(tm);
                row.appendChild(av);
                row.appendChild(wrap);
                container.appendChild(row);
            }

            function fileIcon(type){
                var map = {pdf:'<i class="fas fa-file-pdf"></i>',word:'<i class="fas fa-file-word"></i>',excel:'<i class="fas fa-file-excel"></i>',ppt:'<i class="fas fa-file-powerpoint"></i>',powerbi:'<i class="fas fa-chart-bar"></i>',zip:'<i class="fas fa-file-archive"></i>'};
                return map[type] || '<i class="fas fa-file"></i>';
            }
            function scrollToBottom(){ var el=document.getElementById('chatMessages'); el.scrollTop=el.scrollHeight; }

            // ── Toast notification ──
            function showChatToast(msg, type){
                var old = document.querySelector('.cx-toast');
                if (old) old.remove();
                var t = document.createElement('div');
                t.className = 'cx-toast ' + (type || 'warn');
                t.textContent = msg;
                document.body.appendChild(t);
                setTimeout(function(){
                    t.style.opacity = '0';
                    setTimeout(function(){ if(t.parentNode) t.remove(); }, 400);
                }, 3000);
            }

            // ── Send button cooldown visual ──
            function startSendCooldown(){
                var btn = document.getElementById('chatSendBtn');
                var remaining = 5;
                btn.disabled = true;
                btn.title = 'Wait ' + remaining + 's';
                if (cooldownTimer) clearInterval(cooldownTimer);
                cooldownTimer = setInterval(function(){
                    remaining--;
                    if (remaining <= 0){
                        clearInterval(cooldownTimer);
                        cooldownTimer = null;
                        btn.disabled = false;
                        btn.title = '';
                    } else {
                        btn.title = 'Wait ' + remaining + 's';
                    }
                }, 1000);
            }

            var lastSentAt = 0;
            var cooldownTimer = null;

            window.sendMessage = function(){
                var inp = document.getElementById('chatMsgInput');
                var body = inp.value.trim();
                if (!body && !selectedFile) return;
                if (body.length > 500) { showChatToast('You have exceeded the maximum chat length.', 'error'); return; }
                if (!activeConvId) return;

                // 5-second cooldown between messages
                var now = Date.now();
                var elapsed = now - lastSentAt;
                if (lastSentAt > 0 && elapsed < 5000) {
                    var remaining = Math.ceil((5000 - elapsed) / 1000);
                    showChatToast('Please wait ' + remaining + ' second' + (remaining !== 1 ? 's' : '') + ' before sending again.', 'warn');
                    return;
                }

                var btn = document.getElementById('chatSendBtn');
                btn.disabled = true;
                var fd = new FormData();
                fd.append('conversationId', activeConvId);
                fd.append('body', body);
                fd.append('__RequestVerificationToken', CSRF);
                if (selectedFile) fd.append('file', selectedFile);
                fetch(sendUrl, {method:'POST', credentials:'same-origin', body:fd})
                    .then(function(r){ return r.json(); })
                    .then(function(msg){
                        inp.value = ''; inp.style.height = '';
                        document.getElementById('charCount').textContent = '500';
                        document.getElementById('charCount').className = 'cx-char-count';
                        clearFile();
                        appendMessage(msg);
                        lastMsgId = msg.messageId;
                        lastSentAt = Date.now();
                        scrollToBottom();
                        updateConvListItem(activeConvId, msg);
                        // Start 5s cooldown — keeps button disabled until countdown finishes
                        startSendCooldown();
                    })
                    .catch(function(e){
                        console.error(e);
                        // Only re-enable on error (no cooldown needed if send failed)
                        btn.disabled = false;
                    });
            };

            window.autoGrow = function(el){ el.style.height=''; el.style.height=Math.min(el.scrollHeight,120)+'px'; };
            window.updateCharCount = function(el){
                var rem = 500 - el.value.length;
                var span = document.getElementById('charCount');
                if (!span) return;
                if (rem <= 0) {
                    span.textContent = 'Max length reached';
                    span.className = 'cx-char-count limit';
                    showChatToast('You have exceeded the maximum chat length.', 'error');
                } else {
                    span.textContent = rem;
                    span.className = 'cx-char-count' + (rem<=50?' warn':'');
                }
            };

            window.onFileSelected = function(input){
                if (!input.files[0]) return;
                selectedFile = input.files[0];
                var ext = selectedFile.name.split('.').pop().toLowerCase();
                document.getElementById('chatFileChipIcon').className = ['png','jpg','jpeg'].indexOf(ext)>=0?'fas fa-image':'fas fa-paperclip';
                document.getElementById('chatFileChipName').textContent = selectedFile.name;
                document.getElementById('chatFilePreview').style.display = '';
            };
            window.clearFile = function(){
                selectedFile = null;
                document.getElementById('chatFileInput').value = '';
                document.getElementById('chatFilePreview').style.display = 'none';
            };

            // ── Remove message from DOM (idempotent) ──
            function removeMessageFromDOM(msgId){
                var row = document.querySelector('[data-msg-id="' + msgId + '"]');
                if (!row) return;
                row.remove();
                var container = document.getElementById('chatMessages');
                // Clean orphaned date dividers
                container.querySelectorAll('.cx-date-div').forEach(function(div){
                    var sib = div.nextElementSibling;
                    while (sib && sib.classList.contains('cx-date-div')) sib = sib.nextElementSibling;
                    if (!sib || !sib.classList.contains('cx-msg-row')) div.remove();
                });
                // Show placeholder only if no messages remain
                if (container.querySelectorAll('.cx-msg-row').length === 0) {
                    container.innerHTML = '';
                    var ph = document.createElement('div');
                    ph.dataset.placeholder = '1';
                    ph.style.cssText = 'text-align:center;color:#94a3b8;font-size:.81rem;padding:32px;';
                    ph.textContent = 'No messages yet. Say hello!';
                    container.appendChild(ph);
                }
            }

            // ── Refresh conv list preview to show the actual last message ──
            function refreshConvPreview(convId){
                var item = document.querySelector('[data-conv-id="' + convId + '"]');
                if (!item) return;
                var prev = item.querySelector('.cx-conv-prev');
                var ts   = item.querySelector('.cx-conv-ts');
                if (!prev) return;
                var rows = document.getElementById('chatMessages').querySelectorAll('.cx-msg-row');
                if (rows.length === 0) {
                    prev.textContent = 'No messages yet';
                    if (ts) ts.textContent = '';
                    return;
                }
                var lastRow   = rows[rows.length - 1];
                var bubbleTxt = lastRow.querySelector('.cx-bubble span');
                var fileChip  = lastRow.querySelector('.cx-file-link span');
                var timeEl    = lastRow.querySelector('.cx-msg-time');
                var isMineRow = lastRow.classList.contains('mine');
                var txt = bubbleTxt ? bubbleTxt.textContent : (fileChip ? 'Attachment: ' + fileChip.textContent : '');
                var preview = (isMineRow ? 'You: ' : '') + txt;
                if (preview.length > 38) preview = preview.substring(0, 38) + '...';
                prev.textContent = preview;
                if (ts && timeEl) ts.textContent = timeEl.textContent;
            }

            window.openDeleteModal = function(msgId){ pendingDelete=msgId; document.getElementById('deleteModal').style.display='flex'; };
            window.closeDeleteModal = function(){ pendingDelete=0; document.getElementById('deleteModal').style.display='none'; };
            window.confirmDelete = function(){
                if (!pendingDelete) return;
                var btn = document.getElementById('deleteConfirmBtn');
                btn.disabled=true; btn.textContent='Deleting...';
                var fd = new FormData();
                fd.append('messageId', pendingDelete);
                fd.append('__RequestVerificationToken', CSRF);
                fetch(deleteUrl, {method:'POST', credentials:'same-origin', body:fd})
                    .then(function(r){ return r.json(); })
                    .then(function(d){
                        if (d.success) {
                            // Remove immediately from sender's DOM
                            removeMessageFromDOM(pendingDelete);
                            // Update the left panel preview to show new last message
                            refreshConvPreview(activeConvId);
                        }
                        closeDeleteModal();
                    })
                    .catch(function(){ closeDeleteModal(); })
                    .finally(function(){ btn.disabled=false; btn.textContent='Delete'; });
            };
            document.getElementById('deleteModal').addEventListener('click', function(e){ if(e.target===this) closeDeleteModal(); });

            function markRead(convId){
                var fd = new FormData();
                fd.append('conversationId', convId);
                fd.append('__RequestVerificationToken', CSRF);
                fetch(markReadUrl, {method:'POST', credentials:'same-origin', body:fd})
                    .then(function(r){ return r.json(); })
                    .then(function(d){
                        var item = document.querySelector('[data-conv-id="' + convId + '"]');
                        if (item) { var b=item.querySelector('.cx-unread-dot'); if(b)b.remove(); item.classList.remove('unread'); }
                        updateChatBadge(d.remaining);
                    }).catch(function(){});
            }

            function updateChatBadge(n){
                if (n===undefined){
                    fetch('@Url.Action("GetUnreadCount", "Chat")?_='+Date.now(),{credentials:'same-origin',cache:'no-store'})
                        .then(function(r){return r.json();}).then(function(d){setBadge(d.count);}).catch(function(){});
                } else { setBadge(n); }
            }
            function setBadge(n){ var b=document.getElementById('chatBadgeSidebar'); if(!b)return; if(n>0){b.textContent=n;b.style.display='';}else{b.style.display='none';} }

            function updateConvListItem(convId, msg){
                var item=document.querySelector('[data-conv-id="'+convId+'"]');
                if(!item)return;
                var prev=item.querySelector('.cx-conv-prev');
                var ts  =item.querySelector('.cx-conv-ts');
                if(prev){
                    // Build preview text from the sender's POV
                    var bodyText = msg.body || (msg.attachedFileName ? 'Attachment: '+msg.attachedFileName : '');
                    var previewText = (msg.senderId === ME ? 'You: ' : '') + bodyText;
                    if(previewText.length > 38) previewText = previewText.substring(0,38)+'...';
                    prev.textContent = previewText;
                }
                if(ts) ts.textContent = msg.sentAtDisplay;
                var list=document.getElementById('chatConvList');
                list.insertBefore(item, list.firstChild);
            }

            document.getElementById('chatSearch').addEventListener('input', function(){
                var q=this.value.toLowerCase();
                document.querySelectorAll('.cx-conv-item').forEach(function(i){
                    i.style.display=(i.dataset.otherName||'').toLowerCase().indexOf(q)>=0?'':'none';
                });
            });

            document.getElementById('newChatBtn').addEventListener('click', function(){
                document.getElementById('newChatModal').style.display='flex';
                ['pickRole','pickBranch','pickDept','pickSearch'].forEach(function(id){ document.getElementById(id).value=''; });
                allPeople=[]; loadPeople();
            });
            window.closeNewChatModal = function(){ document.getElementById('newChatModal').style.display='none'; };
            document.getElementById('newChatModal').addEventListener('click', function(e){ if(e.target===this) closeNewChatModal(); });

            var pAbort=null, pTimer=null;
            window.loadPeople = function(){
                clearTimeout(pTimer);
                pTimer=setTimeout(function(){
                    if(pAbort)pAbort.abort();
                    pAbort=new AbortController();
                    var role=document.getElementById('pickRole').value;
                    var branch=document.getElementById('pickBranch').value;
                    var dept=document.getElementById('pickDept').value;
                    document.getElementById('chatPeopleList').innerHTML='<div class="cx-loading"><div class="cx-spinner"></div></div>';
                    fetch(getUsersUrl+'?role='+encodeURIComponent(role)+'&branch='+encodeURIComponent(branch)+'&department='+encodeURIComponent(dept)+'&_='+Date.now(),
                          {credentials:'same-origin',cache:'no-store',signal:pAbort.signal})
                        .then(function(r){return r.json();})
                        .then(function(u){allPeople=u;renderPeople(u);})
                        .catch(function(e){ if(e.name!=='AbortError') document.getElementById('chatPeopleList').innerHTML='<div class="cx-people-empty">Failed to load. Try again.</div>'; });
                },300);
            };
            window.filterPeople = function(){
                var q=document.getElementById('pickSearch').value.toLowerCase();
                if(!allPeople.length){loadPeople();return;}
                renderPeople(q?allPeople.filter(function(p){return p.fullName.toLowerCase().indexOf(q)>=0;}):allPeople);
            };
            function renderPeople(users){
                var list=document.getElementById('chatPeopleList');
                if(!users.length){list.innerHTML='<div class="cx-people-empty">No users found</div>';return;}
                list.innerHTML=users.map(function(u){
                    var ini=u.fullName.split(' ').map(function(p){return p[0];}).join('').substring(0,2).toUpperCase();
                    var av=u.pic?'<img src="/uploads/profiles/'+u.pic+'" alt="">':'<span>'+ini+'</span>';
                    var meta=[u.role,u.department,u.branch].filter(Boolean).join(' · ');
                    return '<div class="cx-person" onclick="selectPerson('+u.userId+',\''+u.fullName.replace(/'/g,"\\'")+'\')"><div class="cx-person-av">'+av+'</div><div class="cx-person-info"><div class="cx-person-name">'+u.fullName+'</div><div class="cx-person-meta">'+meta+'</div></div><span class="cx-role-badge rb-'+u.role.toLowerCase()+'">'+u.role+'</span></div>';
                }).join('');
            }

            window.selectPerson = function(targetId, targetName){
                closeNewChatModal();
                var ex=document.querySelector('[data-other-id="'+targetId+'"]');
                if(ex){openConv(parseInt(ex.dataset.convId),ex);return;}
                document.getElementById('chatEmptyState').style.display='none';
                document.getElementById('chatActive').style.display='';
                document.getElementById('chatMessages').innerHTML='<div class="cx-loading"><div class="cx-spinner"></div></div>';
                document.getElementById('chatHdrName').textContent=targetName;
                document.getElementById('chatHdrMeta').textContent='';
                document.getElementById('chatHdrAvatar').innerHTML='<span>'+targetName.split(' ').map(function(p){return p[0];}).join('').substring(0,2).toUpperCase()+'</span>';
                var fd=new FormData();
                fd.append('targetUserId',targetId);
                fd.append('__RequestVerificationToken',CSRF);
                fetch(getOrCreate,{method:'POST',credentials:'same-origin',body:fd})
                    .then(function(r){return r.json();})
                    .then(function(d){
                        activeConvId=d.conversationId; lastMsgId=0; lastDateLabel='';
                        clearInterval(pollTimer);
                        joinConvGroup(d.conversationId);
                        fetchMessages(true);
                        if(!connection||connection.state!==signalR.HubConnectionState.Connected)
                            pollTimer=setInterval(function(){fetchMessages(false);},3000);
                        addConvToList(d.conversationId,targetId,targetName);
                    }).catch(function(e){console.error(e);});
            };

            function addConvToList(convId,otherId,name){
                var list=document.getElementById('chatConvList');
                var empty=list.querySelector('.cx-conv-empty'); if(empty)empty.remove();
                if(list.querySelector('[data-conv-id="'+convId+'"]'))return;
                var ini=name.split(' ').map(function(p){return p[0];}).join('').substring(0,2).toUpperCase();
                var div=document.createElement('div');
                div.className='cx-conv-item active';
                div.dataset.convId=convId; div.dataset.otherId=otherId;
                div.dataset.otherName=name; div.dataset.otherRole='';
                div.dataset.otherDept=''; div.dataset.otherBranch=''; div.dataset.otherPic='';
                div.setAttribute('onclick','openConv('+convId+',this)');
                div.innerHTML='<div class="cx-conv-av"><span>'+ini+'</span><span class="cx-role-pip"></span></div><div class="cx-conv-info"><div class="cx-conv-row1"><span class="cx-conv-name">'+name+'</span></div><div class="cx-conv-row2"><span class="cx-conv-prev">New conversation</span></div></div>';
                document.querySelectorAll('.cx-conv-item').forEach(function(i){i.classList.remove('active');});
                list.insertBefore(div,list.firstChild);
                div.classList.add('active');
            }

            window.openLightbox = function(src){
                var lb=document.createElement('div'); lb.className='cx-lightbox';
                lb.innerHTML='<img src="'+src+'">';
                lb.addEventListener('click',function(){document.body.removeChild(lb);});
                document.body.appendChild(lb);
            };

            window.showLeftOnMobile = function(){
                document.getElementById('chatLeft').classList.remove('hidden');
                clearInterval(pollTimer); pollTimer=null;
                leaveConvGroup(activeConvId); activeConvId=0;
            };
        })();
    </script>
}
