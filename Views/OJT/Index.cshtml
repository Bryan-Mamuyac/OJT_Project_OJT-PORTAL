@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        (function () {
            var taskChart    = null;
            var analyticsUrl = '@Url.Action("GetAnalytics", "OJT")';
            var rangeSelect  = document.getElementById('rangeSelect');

            rangeSelect.addEventListener('change', loadChart);
            setInterval(loadChart, 300000);
            loadChart();

            function loadChart() {
                var range = rangeSelect.value;
                showState('loading');

                fetch(analyticsUrl + '?range=' + encodeURIComponent(range) + '&_=' + Date.now(), { credentials: 'same-origin', cache: 'no-store' })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        document.getElementById('chartTotalVal').textContent     = data.summary.total;
                        document.getElementById('chartCompletedVal').textContent = data.summary.completed;

                        var hasData = data.summary.total > 0 || data.summary.completed > 0;

                        if (!data.labels || data.labels.length === 0) {
                            showState('empty');
                            return;
                        }
                        if (!hasData) {
                            showState('empty');
                            return;
                        }

                        showState('chart');
                        renderChart(data.labels, data.totalData, data.completedData);
                    })
                    .catch(function (err) {
                        console.error('Chart error:', err);
                        showState('empty');
                    });
            }

            function renderChart(labels, totalData, completedData) {
                var canvas = document.getElementById('taskChart');
                var ctx    = canvas.getContext('2d');

                var gradTotal = ctx.createLinearGradient(0, 0, 0, 260);
                gradTotal.addColorStop(0, 'rgba(37,99,171,0.20)');
                gradTotal.addColorStop(1, 'rgba(37,99,171,0)');

                var gradCompleted = ctx.createLinearGradient(0, 0, 0, 260);
                gradCompleted.addColorStop(0, 'rgba(22,163,74,0.20)');
                gradCompleted.addColorStop(1, 'rgba(22,163,74,0)');

                if (taskChart) { taskChart.destroy(); taskChart = null; }

                taskChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Total Assigned',
                                data: totalData,
                                borderColor: '#2563ab',
                                backgroundColor: gradTotal,
                                borderWidth: 2.5,
                                pointBackgroundColor: '#2563ab',
                                pointBorderColor: '#fff',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 7,
                                fill: true,
                                tension: 0.4
                            },
                            {
                                label: 'Completed',
                                data: completedData,
                                borderColor: '#16a34a',
                                backgroundColor: gradCompleted,
                                borderWidth: 2.5,
                                pointBackgroundColor: '#16a34a',
                                pointBorderColor: '#fff',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 7,
                                fill: true,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                titleColor: '#94a3b8',
                                bodyColor: '#f1f5f9',
                                padding: 12,
                                cornerRadius: 10,
                                borderColor: '#334155',
                                borderWidth: 1,
                                callbacks: {
                                    title: function (items) { return items[0].label; },
                                    label: function (item) {
                                        var n = item.parsed.y;
                                        return ' ' + item.dataset.label + ': ' + n + ' task' + (n !== 1 ? 's' : '');
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: '#f1f5f9' },
                                ticks: {
                                    color: '#94a3b8',
                                    font: { size: 11 },
                                    maxRotation: 45,
                                    maxTicksLimit: 12
                                }
                            },
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f1f5f9' },
                                ticks: {
                                    color: '#94a3b8',
                                    font: { size: 11 },
                                    stepSize: 1,
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }

            function showState(state) {
                document.getElementById('chartLoading').style.display = state === 'loading' ? 'flex'  : 'none';
                document.getElementById('chartWrap').style.display    = state === 'chart'   ? 'block' : 'none';
                document.getElementById('chartEmpty').style.display   = state === 'empty'   ? 'flex'  : 'none';
            }
        })();


            // ── Work Status Modal ──

    </script>
}
