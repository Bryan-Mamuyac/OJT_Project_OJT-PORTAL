@using System.Linq
@model OJTDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="dashboard">

    <!-- STAT CARDS -->
    <div class="stats-grid">
        <div class="stat-card stat-blue">
            <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
            <div class="stat-info">
                <span class="stat-value">@Model.TotalTasks</span>
                <span class="stat-label">Total Tasks</span>
            </div>
        </div>
        <div class="stat-card stat-orange">
            <div class="stat-icon"><i class="fas fa-star"></i></div>
            <div class="stat-info">
                <span class="stat-value">@Model.NewTasks</span>
                <span class="stat-label">New Tasks</span>
            </div>
        </div>
        <div class="stat-card stat-yellow">
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-info">
                <span class="stat-value">@Model.PendingTasks</span>
                <span class="stat-label">Pending Review</span>
            </div>
        </div>
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <span class="stat-value">@Model.CompletedTasks</span>
                <span class="stat-label">Completed</span>
            </div>
        </div>
        <div class="stat-card stat-red">
            <div class="stat-icon"><i class="fas fa-ban"></i></div>
            <div class="stat-info">
                <span class="stat-value">@Model.CancelledTasks</span>
                <span class="stat-label">Cancelled</span>
            </div>
        </div>
    </div>

    <!-- ANALYTICS CHART -->
    <div class="section-card analytics-card">
        <div class="section-header analytics-header">
            <div class="analytics-title">
                <div class="analytics-title-icon"><i class="fas fa-chart-line"></i></div>
                <div>
                    <h3>Task Analytics</h3>
                    <span class="analytics-subtitle">Your task progress over time</span>
                </div>
            </div>
            <div class="analytics-controls">
                <div class="analytics-mini-stats">
                    <div class="mini-stat">
                        <span class="mini-stat-dot dot-total"></span>
                        <span class="mini-stat-label">Total Assigned</span>
                        <span class="mini-stat-val" id="chartTotalVal">0</span>
                    </div>
                    <div class="mini-stat">
                        <span class="mini-stat-dot dot-completed"></span>
                        <span class="mini-stat-label">Completed</span>
                        <span class="mini-stat-val" id="chartCompletedVal">0</span>
                    </div>
                </div>
                <select class="analytics-range-select" id="rangeSelect">
                    <option value="overall" selected>Overall</option>
                    <option value="7">Last 1 Week</option>
                    <option value="14">Last 2 Weeks</option>
                    <option value="30">Last 1 Month</option>
                    <option value="60">Last 2 Months</option>
                    <option value="90">Last 3 Months</option>
                </select>
            </div>
        </div>
        <div class="analytics-body">
            <div class="chart-loading" id="chartLoading">
                <div class="chart-spinner"></div>
                <span>Loading chart data...</span>
            </div>
            <div class="chart-wrap" id="chartWrap" style="display:none;">
                <canvas id="taskChart"></canvas>
            </div>
            <div class="chart-empty" id="chartEmpty" style="display:none;">
                <i class="fas fa-chart-line"></i>
                <p>No task data available yet.</p>
            </div>
        </div>
    </div>

    <!-- TASK LIST -->
    <div class="section-card">
        <div class="section-header">
            <h3><i class="fas fa-tasks"></i> My Assigned Tasks</h3>
            <div style="display:flex;gap:8px;">
                <a asp-action="NewTasks" class="btn btn-outline-sm"><i class="fas fa-star"></i> New</a>
                <a asp-action="PendingTasks" class="btn btn-outline-sm"><i class="fas fa-hourglass-half"></i> Pending</a>
                <a asp-action="CompletedTasks" class="btn btn-outline-sm"><i class="fas fa-check"></i> Completed</a>
            </div>
        </div>
        <div class="section-body">
            @if (!Model.Tasks.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No tasks assigned to you yet.</p>
                </div>
            }
            else
            {
                <div class="task-list">
                    @foreach (var task in Model.Tasks.Take(5))
                    {
                        string cardClass = task.IsOverdue ? "task-card task-overdue"
                        : task.IsNearDeadline ? "task-card task-near-deadline"
                        : "task-card";
                        <div class="@cardClass">
                            <div class="task-card-header">
                                <div class="task-title-area">
                                    <h4>@task.Title</h4>
                                    <span class="status-badge status-@task.Status.ToLower()">@task.Status</span>
                                    @if (task.TaskType == "Group")
                                    {
                                        <span class="status-badge" style="background:#f3e8ff;color:#7c3aed;">
                                            <i class="fas fa-users"></i> Group
                                        </span>
                                    }
                                    @if (task.Status == "Approved")
                                    {
                                        <span class="work-status-badge ws-done">
                                            <i class="fas fa-check-circle" style="font-size:.75rem;"></i> Done
                                        </span>
                                    }
                                    else if (task.WorkStatus != null)
                                    {
                                        <span class="work-status-badge ws-@task.WorkStatus.ToLower().Replace(" ", "-")">
                                            <i class="fas fa-circle" style="font-size:.5rem;"></i> @task.WorkStatus
                                        </span>
                                    }
                                    @if (task.IsOverdue)
                                    {
                                        <span class="deadline-badge overdue">
                                            <i class="fas fa-exclamation-triangle"></i> Overdue
                                        </span>
                                    }
                                    else if (task.IsNearDeadline)
                                    {
                                        <span class="deadline-badge near">
                                            <i class="fas fa-hourglass-half"></i> Due Soon
                                        </span>
                                    }
                                </div>
                                <div class="task-meta">
                                    <span><i class="fas fa-user-tie"></i> @task.AssignedByName</span>
                                    @if (!string.IsNullOrEmpty(task.AssignedByBranch))
                                    {
                                        <span class="meta-branch"><i class="fas fa-map-marker-alt"></i> @task.AssignedByBranch</span>
                                    }
                                    <span><i class="fas fa-calendar-plus"></i> @task.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    @if (task.Deadline.HasValue)
                                    {
                                        string metaCls = task.IsOverdue ? "meta-danger" : task.IsNearDeadline ? "meta-warning" : "";
                                        <span class="@metaCls">
                                            <i class="fas fa-calendar-times"></i> Due: @task.DeadlinePhDisplay
                                        </span>
                                    }
                                </div>
                            </div>
                            <p class="task-desc">@task.Description</p>
                            @{
                                var _taskFiles = task.GetAttachedFiles();
                            }
                            @if (_taskFiles.Any())
                            {
                                <div class="file-chips file-chips-col">
                                    @foreach (var af in _taskFiles)
                                    {
                                        var afExt = System.IO.Path.GetExtension(af.Name).ToLower();
                                        var afIcon = new[] { ".png", ".jpg", ".jpeg" }.Contains(afExt) ? "fas fa-image" :
                                        afExt == ".pbix" ? "fas fa-chart-bar" :
                                        afExt == ".pdf" ? "fas fa-file-pdf" :
                                        new[] { ".xlsx", ".xls" }.Contains(afExt) ? "fas fa-file-excel" :
                                        new[] { ".docx", ".doc" }.Contains(afExt) ? "fas fa-file-word" :
                                        new[] { ".pptx", ".ppt" }.Contains(afExt) ? "fas fa-file-powerpoint" : "fas fa-file";
                                        <a href="@af.Path" class="file-chip" target="_blank" title="@af.Name">
                                            <i class="@afIcon"></i>
                                            <span>@af.Name</span>
                                        </a>
                                    }
                                </div>
                            }
                            <div class="task-actions">
                                <a asp-action="TaskDetails" asp-route-id="@task.TaskId" class="btn btn-outline-sm">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                @if (task.Status == "New")
                                {
                                    @if (task.HasStarted)
                                    {
                                        <a asp-action="SubmitTask" asp-route-id="@task.TaskId" class="btn btn-continue-sm">
                                            <i class="fas fa-circle-play"></i> Continue Task
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="SubmitTask" asp-route-id="@task.TaskId" class="btn btn-start-sm">
                                            <i class="fas fa-circle-play"></i> Start Task
                                        </a>
                                    }
                                }
                                else if (task.Status == "Pending")
                                {
                                    <span class="btn btn-warning-sm disabled">
                                        <i class="fas fa-hourglass-half"></i> Under Review
                                    </span>
                                }
                                else if (task.Status == "Approved")
                                {
                                    <span class="btn btn-success-sm disabled">
                                        <i class="fas fa-check"></i> Approved
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
                @if (Model.Tasks.Count > 5)
                {
                    <div style="text-align:center;padding:12px;">
                        <a asp-action="NewTasks" class="btn btn-outline-sm">
                            View all @Model.Tasks.Count tasks &rarr;
                        </a>
                    </div>
                }
            }
        </div>
    </div>

</div>



