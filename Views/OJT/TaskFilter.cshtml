@using System.Linq
@model List<TaskItem>
@{
    string label = ViewBag.FilterLabel ?? "Tasks";
    string action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewData["Title"] = label;

    string iconClass = action switch
    {
        "NewTasks" => "fas fa-star",
        "PendingTasks" => "fas fa-hourglass-half",
        "CompletedTasks" => "fas fa-check-circle",
        _ => "fas fa-tasks"
    };

    var uniqueBranches = Model.Select(t => t.AssignedByBranch ?? "").Where(b => b != "").Distinct().OrderBy(b => b).ToList();
    var uniqueEmployees = Model.Select(t => t.AssignedByName ?? "").Where(n => n != "").Distinct().OrderBy(n => n).ToList();
    bool showFilters = action == "CompletedTasks" && Model.Any();
}

<div class="dashboard">
    <div class="section-card">
        <div class="section-header" style="flex-wrap:wrap;gap:10px;">
            <h3><i class="@iconClass"></i> @label</h3>
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <div class="tf-search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="taskTitleSearch" placeholder="Search by task title..."
                           oninput="filterTaskCards(this.value)" autocomplete="off" />
                </div>
                <a asp-action="Index" class="btn btn-outline-sm">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>

        @if (showFilters)
        {
            <div class="hf-bar">
                <span class="hf-bar-title"><i class="fas fa-filter"></i> Filter Results</span>
                <div class="hf-controls">
                    @if (uniqueBranches.Any())
                    {
                        <div class="hf-group">
                            <label class="hf-label"><i class="fas fa-map-marker-alt"></i> Branch</label>
                            <select id="filterBranch" class="hf-select" onchange="applyFilters()">
                                <option value="">All Branches</option>
                                @foreach (var b in uniqueBranches)
                                {
                                    <option value="@b">@b</option>
                                }
                            </select>
                        </div>
                    }
                    @if (uniqueEmployees.Any())
                    {
                        <div class="hf-group">
                            <label class="hf-label"><i class="fas fa-user-tie"></i> Employee</label>
                            <select id="filterEmployee" class="hf-select" onchange="applyFilters()">
                                <option value="">All Employees</option>
                                @foreach (var e in uniqueEmployees)
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                    }
                    <button type="button" class="hf-clear" onclick="clearFilters()">
                        <i class="fas fa-times"></i> Clear
                    </button>
                    <span class="hf-result-count"><span id="resultCount">@Model.Count</span> result@(Model.Count != 1 ? "s" : "")</span>
                </div>
            </div>
        }

        <div class="section-body">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="@iconClass"></i>
                    <p>No @label.ToLower() found.</p>
                </div>
            }
            else
            {
                <div class="task-list">
                    @foreach (var task in Model)
                    {
                        <div class="task-card @(task.IsOverdue ? "task-overdue" : task.IsNearDeadline ? "task-near-deadline" : "")"
                             data-branch="@(task.AssignedByBranch ?? "")" data-employee="@(task.AssignedByName ?? "")">
                            <div class="task-card-header">
                                <div class="task-title-area">
                                    <h4>@task.Title</h4>
                                    <span class="status-badge status-@task.Status.ToLower()">@task.Status</span>
                                    @if (task.TaskType == "Group")
                                    {
                                        <span class="status-badge" style="background:#f3e8ff;color:#7c3aed;"><i class="fas fa-users"></i> Group</span>
                                    }
                                    @if (task.Status == "Approved")
                                    {
                                        <span class="work-status-badge ws-done">
                                            <i class="fas fa-check-circle" style="font-size:.75rem;"></i> Done
                                        </span>
                                    }
                                    else if (task.WorkStatus != null)
                                    {
                                        <span class="work-status-badge ws-@task.WorkStatus.ToLower().Replace(" ", "-")">
                                            <i class="fas fa-circle" style="font-size:.5rem;"></i> @task.WorkStatus
                                        </span>
                                    }
                                    @if (task.IsOverdue)
                                    {
                                        <span class="deadline-badge overdue"><i class="fas fa-exclamation-triangle"></i> Overdue</span>
                                    }
                                    else if (task.IsNearDeadline)
                                    {
                                        <span class="deadline-badge near"><i class="fas fa-hourglass-half"></i> Due Soon</span>
                                    }
                                </div>
                                <div class="task-meta">
                                    <span><i class="fas fa-user-tie"></i> @task.AssignedByName</span>
                                    @if (!string.IsNullOrEmpty(task.AssignedByBranch))
                                    {
                                        <span class="meta-branch"><i class="fas fa-map-marker-alt"></i> @task.AssignedByBranch</span>
                                    }
                                    <span><i class="fas fa-calendar-plus"></i> @task.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    @if (task.Deadline.HasValue)
                                    {
                                        <span class="@(task.IsOverdue ? "meta-danger" : task.IsNearDeadline ? "meta-warning" : "")">
                                            <i class="fas fa-calendar-times"></i> Due: @task.DeadlinePhDisplay
                                        </span>
                                    }
                                </div>
                            </div>
                            <p class="task-desc">@task.Description</p>
                            @{
                                var _tFiles = task.GetAttachedFiles();
                            }
                            @if (_tFiles.Any())
                            {
                                <div class="task-attached-section">
                                    <span class="task-attached-label"><i class="fas fa-paperclip"></i> Attached Files</span>
                                    <div class="file-chips file-chips-col">
                                        @foreach (var af in _tFiles)
                                        {
                                            var afExt = System.IO.Path.GetExtension(af.Name).ToLower();
                                            var afIcon = new[] { ".png", ".jpg", ".jpeg" }.Contains(afExt) ? "fas fa-image" :
                                            afExt == ".pbix" ? "fas fa-chart-bar" :
                                            afExt == ".pdf" ? "fas fa-file-pdf" :
                                            new[] { ".xlsx", ".xls" }.Contains(afExt) ? "fas fa-file-excel" :
                                            new[] { ".docx", ".doc" }.Contains(afExt) ? "fas fa-file-word" :
                                            new[] { ".pptx", ".ppt" }.Contains(afExt) ? "fas fa-file-powerpoint" : "fas fa-file";
                                            <a href="@af.Path" class="file-chip" target="_blank" title="@af.Name">
                                                <i class="@afIcon"></i>
                                                <span>@af.Name</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="task-actions">
                                <a asp-action="TaskDetails" asp-route-id="@task.TaskId" class="btn btn-outline-sm">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                @if (task.Status == "New")
                                {
                                    @if (task.HasStarted)
                                    {
                                        <a asp-action="SubmitTask" asp-route-id="@task.TaskId" class="btn btn-continue-sm">
                                            <i class="fas fa-circle-play"></i> Continue Task
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="SubmitTask" asp-route-id="@task.TaskId" class="btn btn-start-sm">
                                            <i class="fas fa-circle-play"></i> Start Task
                                        </a>
                                    }
                                }
                                else if (task.Status == "Pending")
                                {
                                    <span class="btn btn-warning-sm disabled"><i class="fas fa-hourglass-half"></i> Under Review</span>
                                }
                                else if (task.Status == "Approved")
                                {
                                    <span class="btn btn-success-sm disabled"><i class="fas fa-check"></i> Approved</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* ── Filter bar ── */
        .hf-bar {
            padding: 14px 20px;
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .hf-bar-title {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .hf-bar-title i {
                color: #2563ab;
                font-size: .65rem;
            }

        .hf-controls {
            display: flex;
            align-items: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .hf-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .hf-label {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .hf-label i {
                font-size: .6rem;
                color: #2563ab;
            }

        .hf-select {
            height: 34px;
            padding: 0 10px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #1e293b;
            font-size: .82rem;
            cursor: pointer;
            outline: none;
            min-width: 150px;
            transition: border-color .15s;
        }

            .hf-select:focus {
                border-color: #2563ab;
            }

        .hf-clear {
            height: 34px;
            padding: 0 14px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #fff;
            color: #64748b;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: all .15s;
            align-self: flex-end;
        }

            .hf-clear:hover {
                border-color: #94a3b8;
                background: #f1f5f9;
                color: #1e293b;
            }

        .hf-result-count {
            font-size: .8rem;
            font-weight: 600;
            color: #64748b;
            align-self: flex-end;
            padding-bottom: 7px;
        }

        .task-card.tf-hidden {
            display: none !important;
        }

        /* Task card extras */
        .btn-start-sm {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: .8rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            background: linear-gradient(135deg,#059669,#047857);
            color: #fff;
            transition: opacity .15s;
        }

        .btn-continue-sm {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: .8rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            background: linear-gradient(135deg,#2563ab,#1e40af);
            color: #fff;
            transition: opacity .15s;
        }

            .btn-start-sm:hover, .btn-continue-sm:hover {
                opacity: .88;
            }

        .task-overdue {
            border-left: 4px solid #dc2626 !important;
            background: #fff5f5;
        }

        .task-near-deadline {
            border-left: 4px solid #d97706 !important;
            background: #fffbeb;
        }

        .deadline-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: .72rem;
            font-weight: 600;
        }

            .deadline-badge.overdue {
                background: #fee2e2;
                color: #b91c1c;
            }

            .deadline-badge.near {
                background: #fef3c7;
                color: #b45309;
            }

        .meta-danger {
            color: #dc2626 !important;
        }

        .meta-warning {
            color: #d97706 !important;
        }

        .meta-branch {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: .72rem;
            font-weight: 600;
            color: #0369a1;
            background: #e0f2fe;
            padding: 1px 7px;
            border-radius: 20px;
        }

            .meta-branch i {
                font-size: .6rem;
            }

        .file-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 4px;
        }

        .file-chips-col {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-top: 6px;
        }

        .file-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 13px;
            border-radius: 8px;
            background: #f0f7ff;
            border: 1px solid #bfdbfe;
            color: #1d4ed8;
            font-size: .82rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .15s,border-color .15s;
            width: fit-content;
            max-width: 100%;
        }

            .file-chip span {
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .file-chip:hover {
                background: #dbeafe;
                border-color: #93c5fd;
                color: #1e40af;
            }

            .file-chip i {
                font-size: .8rem;
            }

        .task-attached-section {
            margin-top: 10px;
        }

        .task-attached-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .75rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .4px;
            margin-bottom: 6px;
        }

            .task-attached-label i {
                color: #2563ab;
            }

        .tf-search-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 0 12px;
            height: 36px;
            min-width: 220px;
        }

            .tf-search-wrap i {
                color: #94a3b8;
                font-size: .78rem;
                flex-shrink: 0;
            }

            .tf-search-wrap input {
                border: none;
                background: transparent;
                outline: none;
                font-size: .83rem;
                color: #374151;
                width: 100%;
            }

        .tf-no-results {
            text-align: center;
            padding: 32px;
            color: #94a3b8;
            font-size: .85rem;
            display: none;
        }
    </style>
}

<div class="tf-no-results" id="tfNoResults">
    <i class="fas fa-search" style="font-size:1.8rem;display:block;margin-bottom:8px;opacity:.4;"></i>
    No tasks found matching your search.
</div>

@section Scripts {
    <script>
        function applyFilters() {
            var branch   = (document.getElementById("filterBranch")   || { value: "" }).value;
            var employee = (document.getElementById("filterEmployee") || { value: "" }).value;
            var cards    = document.querySelectorAll(".task-card[data-branch]");
            var visible  = 0;
            cards.forEach(function (card) {
                var show = (!branch   || card.dataset.branch   === branch) &&
                           (!employee || card.dataset.employee === employee);
                card.classList.toggle("tf-hidden", !show);
                if (show) visible++;
            });
            var el = document.getElementById("resultCount");
            if (el) el.textContent = visible;
        }

        function clearFilters() {
            var fb = document.getElementById("filterBranch");
            var fe = document.getElementById("filterEmployee");
            if (fb) fb.value = "";
            if (fe) fe.value = "";
            applyFilters();
        }

        function filterTaskCards(query) {
            var q = query.toLowerCase().trim();
            var cards = document.querySelectorAll('.task-card');
            var visible = 0;
            cards.forEach(function(card) {
                var titleEl = card.querySelector('.task-title-area h4');
                var title = titleEl ? titleEl.textContent.toLowerCase() : '';
                var match = !q || title.indexOf(q) !== -1;
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            var noRes = document.getElementById('tfNoResults');
            if (noRes) noRes.style.display = (visible === 0 && q) ? 'block' : 'none';
        }
    </script>
}
