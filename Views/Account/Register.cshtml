@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
    var departments = new[] { "IT","HR","GLL","SSDG","Accounting","Treasury","TMG",
                               "Legal Service","Production","Electrical Engineer",
                               "Mechanical Engineer","Agronomy" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register – OJT Portal</title>
    <link rel="icon" type="image/png" href="~/Assets/logo_final.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-body">
    <div class="auth-container">

        <!-- Left branding panel -->
        <div class="auth-left">
            <div class="auth-branding">
                <div class="brand-icon-img">
                    <img src="~/Assets/logo_final.png" alt="OJT Portal Logo" />
                </div>
                <h1>OJT Portal</h1>
                <p>On-the-Job Training Management System</p>
                <div class="register-note">
                    <i class="fas fa-info-circle"></i>
                    <div>
                        <strong>Registration Note</strong>
                        <p>After submitting, your account will be reviewed and approved by an administrator before you can log in.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-right auth-right-scroll">
            <div class="auth-card">
                <div class="auth-card-header">
                    <h2>Create Account</h2>
                    <p>Fill in your details to register</p>
                </div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Role"><i class="fas fa-id-badge"></i> Register As</label>
                            <select asp-for="Role" class="form-control">
                                <option value="">-- Select Role --</option>
                                <option value="OJT">OJT Trainee</option>
                                <option value="Employee">Employee Tasker</option>
                            </select>
                            <span asp-validation-for="Role" class="field-error"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Department"><i class="fas fa-building"></i> Department</label>
                            <select asp-for="Department" class="form-control">
                                <option value="">-- Select Department --</option>
                                @foreach (var d in departments)
                                {
                                    <option value="@d">@d</option>
                                }
                            </select>
                            <span asp-validation-for="Department" class="field-error"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email"><i class="fas fa-envelope"></i> Email Address</label>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com" type="email" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="FirstName"><i class="fas fa-user"></i> First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="First name" />
                            <span asp-validation-for="FirstName" class="field-error"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="LastName"><i class="fas fa-user"></i> Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Last name" />
                            <span asp-validation-for="LastName" class="field-error"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Username"><i class="fas fa-at"></i> Username</label>
                        <input asp-for="Username" class="form-control" placeholder="Choose a username" autocomplete="username" />
                        <span asp-validation-for="Username" class="field-error"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Password"><i class="fas fa-lock"></i> Password</label>
                            <div class="input-with-icon">
                                <input asp-for="Password" class="form-control" type="password"
                                       placeholder="Create password" id="pw1" autocomplete="new-password" />
                                <button type="button" class="toggle-password" onclick="togglePw('pw1',this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword"><i class="fas fa-lock"></i> Confirm Password</label>
                            <div class="input-with-icon">
                                <input asp-for="ConfirmPassword" class="form-control" type="password"
                                       placeholder="Repeat password" id="pw2" autocomplete="new-password" />
                                <button type="button" class="toggle-password" onclick="togglePw('pw2',this)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary-full">
                        <i class="fas fa-user-plus"></i> Create Account
                    </button>
                </form>

                <div class="auth-footer">
                    <p>Already have an account? <a asp-action="Login">Sign in here</a></p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            const ico = btn.querySelector('i');
            if (inp.type === 'password') { inp.type = 'text'; ico.classList.replace('fa-eye','fa-eye-slash'); }
            else { inp.type = 'password'; ico.classList.replace('fa-eye-slash','fa-eye'); }
        }
    </script>
</body>
</html>
