@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password – INTERNIFY</title>
    <link rel="icon" type="image/png" href="~/Assets/logo_final.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <style>
        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear,
        input[type="password"]::-webkit-credentials-auto-fill-button {
            display: none !important;
        }
    </style>
</head>
<body class="auth-body">
    <div class="auth-container">

        <!-- Left branding panel -->
        <div class="auth-left">
            <div class="auth-branding">
                <div class="brand-icon-img">
                    <img src="~/Assets/logo_final.png" alt="INTERNIFY Logo" />
                </div>
                <h1>INTERNIFY</h1>
                <p>Your Portal to Real-Life Work Experience</p>
                <div class="auth-features">
                    <div class="feature-item"><i class="fas fa-lock"></i><span>Secure Your Account</span></div>
                    <div class="feature-item"><i class="fas fa-shield-alt"></i><span>Password Protected</span></div>
                    <div class="feature-item"><i class="fas fa-key"></i><span>First Login Setup</span></div>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-right">
            <div class="auth-card">
                <div class="auth-card-header">
                    <div style="display:flex;justify-content:center;margin-bottom:12px;">
                        <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-key" style="color:#fff;font-size:1.4rem;"></i>
                        </div>
                    </div>
                    <h2>Set Your Password</h2>
                    <p>Your account was created by an admin. Please set a new password to continue.</p>
                </div>

                <div class="alert" style="background:#fef3c7;border:1px solid #fcd34d;color:#92400e;border-radius:10px;padding:12px 16px;margin:0 24px 4px;font-size:.875rem;display:flex;gap:10px;align-items:center;">
                    <i class="fas fa-exclamation-triangle" style="flex-shrink:0;"></i>
                    <span>You must change your password before accessing the system.</span>
                </div>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="form-group">
                        <label asp-for="NewPassword"><i class="fas fa-lock"></i> New Password</label>
                        <div class="input-with-icon">
                            <input asp-for="NewPassword" class="form-control" type="password"
                                   placeholder="At least 6 characters" id="pwNew" autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="togglePw('pwNew',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ConfirmPassword"><i class="fas fa-lock"></i> Confirm Password</label>
                        <div class="input-with-icon">
                            <input asp-for="ConfirmPassword" class="form-control" type="password"
                                   placeholder="Repeat your new password" id="pwConfirm" autocomplete="new-password" />
                            <button type="button" class="toggle-password" onclick="togglePw('pwConfirm',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>

                    <div style="padding:0 24px 24px;">
                        <button type="submit" class="btn-primary-full">
                            <i class="fas fa-check"></i> Set Password & Continue
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            const ico = btn.querySelector('i');
            if (inp.type === 'password') { inp.type = 'text'; ico.classList.replace('fa-eye','fa-eye-slash'); }
            else { inp.type = 'password'; ico.classList.replace('fa-eye-slash','fa-eye'); }
        }
    </script>
</body>
</html>