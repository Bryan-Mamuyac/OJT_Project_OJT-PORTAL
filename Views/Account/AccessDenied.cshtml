@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Access Denied – OJT Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter',sans-serif;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0
        }

        .box {
            text-align: center;
            background: #fff;
            border-radius: 16px;
            padding: 60px 48px;
            box-shadow: 0 8px 32px rgba(0,0,0,.12);
            max-width: 420px
        }

        .icon {
            font-size: 4rem;
            margin-bottom: 16px
        }

        h1 {
            font-size: 1.5rem;
            color: #0f172a;
            margin-bottom: 8px
        }

        p {
            color: #64748b;
            margin-bottom: 24px
        }

        a {
            background: #1a3a5c;
            color: #fff;
            padding: 10px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            display: inline-block
        }

            a:hover {
                background: #2563ab
            }
    </style>
</head>
<body>
    <div class="box">
        <div class="icon">🔒</div>
        <h1>Access Denied</h1>
        <p>You don't have permission to view this page.</p>
        <a href="/">Return Home</a>
    </div>
</body>
</html>
